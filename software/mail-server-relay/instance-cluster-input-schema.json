{
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cluster Input Parameters",
  "definitions": {
    "fqdn": {
      "title": "Fully Qualified Domain Name",
      "description": "The public fully qualified domain name referencing this relay node",
      "type": "string",
      "pattern": "^.+$"
    },
    "relay-config": {
      "type": "object",
      "properties": {
        "proxy-map": {
          "title": "Proxy Map",
          "description": "Map containing proxy accounts useable by this cluster. Keys are arbitrary identifiers, and values are objects with the following properties: 'host' (string), 'port' (integer), 'user' (string), 'password' (string), and 'domains' (array of strings).",
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "pattern": "^.+$",
                "description": "The host to proxy the emails to"
              },
              "port": {
                "type": "integer",
                "description": "The port used by the proxy",
                "default": 25
              },
              "user": {
                "type": "string",
                "pattern": "^.+$",
                "description": "The user to authenticate with the proxy host"
              },
              "password": {
                "type": "string",
                "pattern": "^.+$",
                "description": "The password to authenticate with the proxy host"
              },
              "domains": {
                "type": "array",
                "description": "List of domains that should be proxied to this host, one entry per item.",
                "items": {
                  "type": "string",
                  "pattern": "^.+$"
                },
                "default": []
              }
            },
            "required": [
              "host",
              "port"
            ],
            "additionalProperties": false
          },
          "default": {}
        },
        "greylisting": {
          "title": "Greylisting",
          "description": "Greylisting configuration for inbound mail.",
          "type": "object",
          "properties": {
            "enable": {
              "title": "Enable Greylisting",
              "description": "Whether to enable greylisting on inbound mail",
              "type": "boolean",
              "default": true
            },
            "delay": {
              "title": "Greylist Delay",
              "description": "Seconds a new sender triplet must wait before being accepted",
              "type": "integer",
              "default": 60
            },
            "whitelist-clients": {
              "title": "Greylisting Whitelist Clients",
              "description": "Additional client patterns to whitelist in postgrey, one entry per item.",
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^.+$"
              },
              "default": []
            },
            "whitelist-recipients": {
              "title": "Greylisting Whitelist Recipients",
              "description": "Additional recipient patterns to whitelist in postgrey, one entry per item.",
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^.+$"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "enable": true,
            "delay": 60,
            "whitelist-clients": [],
            "whitelist-recipients": []
          }
        }
      }
    }
  },
  "properties": {
    "default-relay-config": {
      "$ref": "#/definitions/relay-config",
      "default": {}
    },
    "omailgw": {
      "title": "oMailGw",
      "description": "Built-in oMailGw deployment for relay monitoring and administration.",
      "type": "object",
      "properties": {
        "enable": {
          "title": "Enable oMailGw",
          "description": "Deploy the oMailGw API/UI child instance and configure relay-side clients.",
          "type": "boolean",
          "default": false
        },
        "relay-poll-interval": {
          "title": "Relay Poll Interval",
          "description": "Seconds between oMailGw CLI polling runs on each relay.",
          "type": "integer",
          "minimum": 60,
          "default": 300
        }
      },
      "additionalProperties": false,
      "default": {
        "enable": false,
        "relay-poll-interval": 300
      }
    },
    "relay-domain": {
      "title": "Relay Domain",
      "description": "The domain that will point to all relay instances",
      "type": "string"
    },
    "topology": {
      "title": "Topology",
      "description": "Cluster topology configuration",
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9-]+$": {
          "type": "object",
          "properties": {
            "fqdn": {
              "$ref": "#/definitions/fqdn"
            },
            "sla": {
              "type": "object",
              "description": "SLA parameters for the instance",
              "properties": {
                "instance_guid": {
                  "type": "string",
                  "description": "Unique identifier of the instance"
                },
                "computer_guid": {
                  "type": "string",
                  "description": "Unique identifier of the computer"
                }
              },
              "additionalProperties": true
            },
            "sr-url": {
              "type": "string",
              "description": "Software release URL for this relay. If empty, defaults to the cluster's software release URL."
            },
            "software-type": {
              "type": "string",
              "description": "Software type for this relay.",
              "default": "relay"
            },
            "state": {
              "type": "string",
              "enum": [
                "started",
                "destroyed",
                "stopped"
              ],
              "default": "started"
            },
            "config": {
              "$ref": "#/definitions/relay-config"
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "topology"
  ]
}
