[buildout]
extends =
  ${monitor2-template:output}
parts =
  validate-proxy-map
  monitor-base
  publish-connection-information
  publish-shared

eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true

[validate-proxy-map]
recipe = slapos.recipe.build
proxy-map = {{
  dumps(slapparameter_dict.get('default-relay-config', {}).get('proxy-map', {}))
}}
init =
  # Validate that domains are unique across all proxies in proxy-map
  proxy_map = options['proxy-map']
  domain_to_proxy = {}
  errors = []
  for proxy_id, proxy_config in proxy_map.items():
    for domain in proxy_config.get('domains', []):
      if domain in domain_to_proxy:
        errors.append(
          f"Domain '{domain}' appears in multiple proxies: "
          f"'{domain_to_proxy[domain]}' and '{proxy_id}'. "
          f"Each domain must appear in only one proxy's domains list."
        )
      else:
        domain_to_proxy[domain] = proxy_id
  options['validated-domains'] = str(len(domain_to_proxy))
  options['errors'] = errors
  options['domain-to-proxy'] = domain_to_proxy

[cluster-mx]
recipe = slapos.recipe.build
topology = {{ dumps(slapparameter_dict.get('topology', {})) }}
init =
  # Collect a list of the relay nodes' fully qualified domain names
  fqdn_list = []
  for config in options['topology'].values():
    fqdn = config.get('fqdn')
    if fqdn:
      fqdn_list.append(fqdn)
  options['fqdn-list'] = fqdn_list
  options['dns-template'] = '\n'.join(
    "%%(name)s. MX 10 %s." % fqdn
    for fqdn in fqdn_list
  )

[request-relay-base]
<= slap-connection
recipe = slapos.cookbook:request.serialised
config-monitor-password = $${monitor-instance-parameter:password}
{% for key, value in slapparameter_dict['default-relay-config'].items() -%}
config-{{ key }} = {{ dumps(value) }}
{% endfor -%}
config-mail-domains = $${filter-shared-instances:accepted-domain-relays}
config-cluster-fqdns = $${cluster-mx:fqdn-list}
return =
  smtp-ipv6
  smtp-port
  tls-fingerprints

{% for relay_name, config in slapparameter_dict['topology'].items() -%}
{% set relay_fqdn = config.get('fqdn') -%}
[request-relay-{{ relay_name }}]
<= request-relay-base
name = {{ relay_name }}
state = {{ config['state'] }}
software-url = {{ config.get('sr-url') or '$${:software-release-url}' }}
software-type = {{ config.get('software-type') or 'relay' }}

{% if relay_fqdn -%}
config-fqdn = {{ relay_fqdn }}
{%- endif %}

{% for key, value in config.get('config', {}).items() -%}
config-{{ key }} = {{ dumps(value) }}
{% endfor -%}

{% for key, value in config.get('sla', {}).items() -%}
sla-{{ key }} = {{ dumps(value) }}
{% endfor -%}

{% endfor -%}

[request-all-relays]
recipe = slapos.recipe.build
{# order is stable because Python3 dicts have stable order -#}
relay-names = {{ dumps(list(slapparameter_dict['topology'].keys())) }}
init =
  fingerprints = []
  hosts = []
  for relay_name in options['relay-names']:
    part = self.buildout['request-relay-' + relay_name]
    fingerprints.extend(part['connection-tls-fingerprints'])
    hosts.append(part['connection-smtp-ipv6'])
  options['tls-fingerprints'] = fingerprints
  options['hosts'] = hosts
{% if "relay-domain" in slapparameter_dict %}
relay-host = {{ slapparameter_dict['relay-domain'] }}
{% else %}
# TODO: use multiple relays when supported
relay-host = $${request-relay-{{ next(iter(slapparameter_dict['topology'].keys())) }}:connection-smtp-ipv6}
{% endif %}

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
relay-hosts = $${request-all-relays:hosts}
backend-domains = $${filter-shared-instances:backend-domains}
errors = $${validate-proxy-map:errors}


# Shared instances (domains)
# ----------------------------

[filter-shared-instances]
recipe = slapos.recipe.build
# JSON store for mapping domain -> shared reference
# Requesting same (reference, domain) again is a no-op, this happens normally
# Error only if a different reference claims an already assigned domain
target = $${directory:etc}/relay-domains.json
shared-list = $${slap-configuration:valid-shared-instance-list}
init =
  import json
  import secrets
  target = options['target']

  try:
    with open(target, 'r') as fp:
      previous = json.load(fp)
  except FileNotFoundError:
    print("No previous shared instances found")
    previous = {}

  shared_list = options['shared-list']
  pub_domain_dict = {}
  output = {}

  def make_entry(shared, prev=None):
    authentication = shared['parameters']['authentication']
    entry = {
      **shared['parameters'],
      'reference': shared['reference'],
    }
    # For password-auth domains, generate or reuse a password
    if authentication == 'password':
      prev = prev or {}
      if prev.get('authentication') == 'password' and prev.get('password'):
        entry['password'] = prev['password']
      else:
        entry['password'] = secrets.token_urlsafe(24)
    return entry

  # 1st pass: keep only shareds matching both domain and reference
  # (= previously accepted shareds)
  for shared in shared_list:
    domain = shared['parameters']['name']
    if prev_entry := previous.get(domain):
      if prev_entry['reference'] == shared['reference']:
        entry = output[domain] = make_entry(shared, prev_entry)
        pub_domain_dict[shared['reference']] = entry
      else:
        # domain is already used by another shared, 2nd pass will handle it
        pass
    else:
      # new domain, 2nd pass will handle it
      pass

  # 2nd pass: claim unclaimed domains, error on duplicates
  for shared in shared_list:
    domain = shared['parameters']['name']
    # If address was already processed in 1st pass
    if existing := output.get(domain):
      if existing['reference'] != shared['reference']:
        pub_domain_dict[shared['reference']] = {
          'domain': domain,
          'error': 'address_already_used',
        }
      # (if it matches, nothing to do)
    else:
      # address not yet claimed
      entry = output[domain] = make_entry(shared)
      pub_domain_dict[shared['reference']] = entry

  self.output = output

  options['published-domain-dict'] = pub_domain_dict
  options['accepted-domain-relays'] = list(output.values())
  options['backend-domains'] = '\n'.join(e['name'] for e in output.values())

  options['location'] = ''  # we don't care about the part folder existing
install =
  import json
  with open(options['target'], 'w') as fp:
    json.dump(self.output, fp, sort_keys=True)

[publish-shared]
recipe = slapos.recipe.build
published-domain-dict = $${filter-shared-instances:published-domain-dict}
domain-to-proxy-map = $${validate-proxy-map:domain-to-proxy}
dns-template = $${cluster-mx:dns-template}
template =
  [publish-shared-%(shared-ref)s]
  recipe = slapos.cookbook:publish.serialised
  -slave-reference = %(shared-ref)s
error-template =
  $${:template}
  domain = %(domain)s
  error = %(error)s
ok-template =
  $${:template}
  dns-entries = %(dns-entries)s
  tls-fingerprints = %(relay-fingerprints)s
  outbound-host = %(relay-host)s
  outbound-smtp-port = 10587
  outbound-has-proxy = %(has-proxy)s
password-template =
  $${:ok-template}
  outbound-user = %(name)s
  outbound-password = %(password)s
{% raw -%}
init =
  from zc.buildout.buildout import dumps
  dns_template = options['dns-template']
  for shared_ref, entry in options['published-domain-dict'].items():
    if 'error' in entry:
      section = options['error-template'] % {
        **entry,
        'shared-ref': shared_ref,
      }
    else:
      pwd = entry.get('authentication') == 'password' and entry.get('password')
      template = options['password-template' if pwd else 'ok-template']
      section = template % {
        **entry,
        'shared-ref': shared_ref,
        'dns-entries': dumps(dns_template % entry),
        'relay-fingerprints': '$$' + '{request-all-relays:tls-fingerprints}',
        'relay-host': '$$' + '{request-all-relays:relay-host}',
        'has-proxy': dumps(entry['name'] in options['domain-to-proxy-map']),
      }
    self.buildout.parse(section)
{%- endraw %}

