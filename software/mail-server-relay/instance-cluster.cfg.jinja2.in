[buildout]
extends =
  ${monitor2-template:output}
parts =
  validate-proxy-map
  monitor-base
  publish-connection-information
  publish-shared

eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true

{% set omailgw_parameter_dict = slapparameter_dict['omailgw'] %}
{% set omailgw_enable = omailgw_parameter_dict['enable'] %}
{% set omailgw_relay_hostname_list = [] -%}
{% for relay_name, config in slapparameter_dict['topology'].items() -%}
{%   if config['state'] != 'destroyed' -%}
{%     do omailgw_relay_hostname_list.append(relay_name) -%}
{%   endif -%}
{% endfor -%}

[validate-proxy-map]
recipe = slapos.recipe.build
init =
  # Validate that domains are unique across all proxies in proxy-map
  proxy_map = {{ slapparameter_dict['default-relay-config']['proxy-map'] }}
  domain_to_proxy = {}
  errors = []
  
  for proxy_id, proxy_config in proxy_map.items():
    for domain in proxy_config['domains']:
      if domain in domain_to_proxy:
        errors.append(
          f"Domain '{domain}' appears in multiple proxies: "
          f"'{domain_to_proxy[domain]}' and '{proxy_id}'. "
          f"Each domain must appear in only one proxy's domains list."
        )
      else:
        domain_to_proxy[domain] = proxy_id
  
  options['validated-domains'] = str(len(domain_to_proxy))
  options['errors'] = errors
  options['domain-to-proxy'] = domain_to_proxy

{% if omailgw_enable %}
[request-omailgw]
<= slap-connection
recipe = slapos.cookbook:request.serialised
name = omailgw
state = started
config-monitor-password = $${monitor-instance-parameter:password}
software-url = $${:software-release-url}
software-type = omailgw
config-relay-hostname-list = {{ dumps(omailgw_relay_hostname_list) }}
config-relay-domain = {{ dumps(slapparameter_dict.get('relay-domain', 'omailgw.local')) }}
config-relay-poll-interval = {{ dumps(omailgw_parameter_dict['relay-poll-interval']) }}
return =
  api-url
  ui-url
  root-user
  root-password
  mailgw-user
  mailgw-password
{% endif %}

[request-relay-base]
<= slap-connection
recipe = slapos.cookbook:request.serialised
config-monitor-password = $${monitor-instance-parameter:password}
{% for key, value in slapparameter_dict['default-relay-config'].items() -%}
config-{{ key }} = {{ dumps(value) }}
{% endfor -%}
config-mail-domains = $${filter-shared-instances:accepted-domain-list}
return =
  smtp-ipv6
  smtp-port
  tls-fingerprints

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
dns-entries = $${filter-shared-instances:dns-entries}
errors = $${validate-proxy-map:errors}
{% if omailgw_enable %}
omailgw-api-url = $${request-omailgw:connection-api-url}
omailgw-ui-url = $${request-omailgw:connection-ui-url}
omailgw-root-user = $${request-omailgw:connection-root-user}
omailgw-root-password = $${request-omailgw:connection-root-password}
{% endif %}

{% for relay_name, config in slapparameter_dict['topology'].items() -%}
{% if omailgw_enable %}
[omailgw-relay-parameters-{{ relay_name }}]
recipe = slapos.recipe.build
init =
  options['omailgw'] = {
    'enable': True,
    'api-url': self.buildout['request-omailgw']['connection-api-url'],
    'api-user': self.buildout['request-omailgw']['connection-mailgw-user'],
    'api-password': self.buildout['request-omailgw']['connection-mailgw-password'],
    'server-hostname': {{ repr(relay_name) }},
    'relay-poll-interval': {{ omailgw_parameter_dict['relay-poll-interval'] }},
  }
{% endif %}

[request-relay-{{ relay_name }}]
<= request-relay-base
name = {{ relay_name }}
state = {{ config['state'] }}
software-url = {{ config.get('sr-url') or '$${:software-release-url}' }}
software-type = {{ config['software-type'] }}
{% if omailgw_enable %}
config-omailgw = $${omailgw-relay-parameters-{{ relay_name }}:omailgw}
{% endif %}

{% for key, value in config.get('config', {}).items() -%}
config-{{ key }} = {{ dumps(value) }}
{% endfor -%}

{% for key, value in config.get('sla', {}).items() -%}
sla-{{ key }} = {{ dumps(value) }}
{% endfor -%}

{% endfor -%}

[request-all-relays]
recipe = slapos.recipe.build
{# order is stable because Python3 dicts have stable order -#}
relay-names = {{ dumps(list(slapparameter_dict['topology'].keys())) }}
init =
  fingerprints = []
  hosts = []
  for relay_name in options['relay-names']:
    part = self.buildout['request-relay-' + relay_name]
    fingerprints.extend(part['connection-tls-fingerprints'])
    hosts.append(part['connection-smtp-ipv6'])
  options['tls-fingerprints'] = fingerprints
  options['hosts'] = hosts
{% if "relay-domain" in slapparameter_dict %}
relay-host = {{ slapparameter_dict['relay-domain'] }}
{% else %}
# TODO: use multiple relays when supported
relay-host = $${request-relay-{{ next(iter(slapparameter_dict['topology'].keys())) }}:connection-smtp-ipv6}
{% endif %}


# Shared instances (domains)
# ----------------------------

[filter-shared-instances]
recipe = slapos.recipe.build
# JSON store for mapping domain -> slave reference
# Requesting same (reference, domain) again is a no-op, this happens normally
# Error only if a different reference claims an already assigned domain
target = $${directory:etc}/relay-domains.json
init =
  import json
  import secrets
  target = options['target']

  try:
    with open(target, 'r') as fp:
      previous = json.load(fp)
  except FileNotFoundError:
    print("No previous shared instances found")
    previous = {}

  pub_domain_dict = {}
  output = {}

  slave_list = {{ (slap_configuration.get('valid-shared-instance-list', [])) }}

  def make_entry(slave):
    authentication = slave['parameters']['authentication']
    entry = {
      **slave['parameters'],
      'reference': slave['reference'],
    }
    # For password-auth domains, generate or reuse a password
    if authentication == 'password':
      prev = previous.get(slave['parameters']['name'], {})
      if prev.get('authentication') == 'password' and prev.get('reference') == slave['reference'] and prev.get('password'):
        entry['password'] = prev['password']
      else:
        entry['password'] = secrets.token_urlsafe(24)
    return entry

  # 1st pass: keep only slaves matching both domain and reference ( = previously accepted slaves)
  for slave in slave_list:
    domain = slave['parameters']['name']
    
    if prev_entry := previous.get(domain):
      if prev_entry['reference'] == slave['reference']:
        entry = output[domain] = make_entry(slave)
        pub_domain_dict[slave['reference']] = {
          'addr': domain,
          'authentication': entry['authentication'],
          # 'password' field is specific to 'authentication' == 'password' case
          'password': entry.get('password', '')
        }
      else:
        # domain is already used by another slave, 2nd pass will handle it
        pass
    else:
      # new domain, 2nd pass will handle it
      pass

  # 2nd pass: claim unclaimed domains, error on duplicates
  for slave in slave_list:
    domain = slave['parameters']['name']
    
    # If address was already processed in 1st pass
    if existing := output.get(domain):
      if existing['reference'] != slave['reference']:
        pub_domain_dict[slave['reference']] = {'addr': domain, 'error': 'address_already_used'}
      # (if it matches, nothing to do)
    else:
      # address not yet claimed
      entry = output[domain] = make_entry(slave)
      pub_domain_dict[slave['reference']] = {
        'addr': domain,
        'authentication': entry['authentication'],
        # 'password' field is specific to 'authentication' == 'password' case
        'password': entry.get('password', '')
      }

  options['published-domain-dict'] = pub_domain_dict
  options['accepted-domain-list'] = list(output.values())
  options['dns-entries'] = "\n".join(
    f"  {entry['name']} MX 10 {self.buildout['request-all-relays']['relay-host']}"
    for entry in output.values()
  )

  self.output = output

  options['location'] = ''  # we don't care about the part folder existing
install =
  import json
  with open(options['target'], 'w') as fp:
    json.dump(self.output, fp, sort_keys=True)

[publish-shared]
recipe = slapos.recipe.build
published-domain-dict = $${filter-shared-instances:published-domain-dict}
relay-tls-fingerprints = $${request-all-relays:tls-fingerprints}
domain-to-proxy-map = $${validate-proxy-map:domain-to-proxy}
{% raw -%}
init =
  import textwrap
  from zc.buildout.buildout import dumps
  dollar = '$$'
  for slave_ref, info in options['published-domain-dict'].items():
    section = textwrap.dedent(f"""
      [publish-shared-{slave_ref}]
      recipe = slapos.cookbook:publish.serialised
      -slave-reference = {slave_ref}""")
    if 'error' in info:
      section += textwrap.dedent(f"""
        domain = {info['addr']}
        error = {info['error']}""")
    else:
      section += textwrap.dedent(f"""
        dns-entries =
          {info['addr']} MX 10 {self.buildout['request-all-relays']['relay-host']}
        tls-fingerprints = {dollar}{{request-all-relays:tls-fingerprints}}""")
      if info.get('authentication') == 'password' and info.get('password'):
        section += textwrap.dedent(f"""
          outbound-host = {self.buildout['request-all-relays']['relay-host']}
          outbound-smtp-port = 10587
          outbound-user = {info['addr']}
          outbound-password = {info['password']}""")
      else:
        section += textwrap.dedent(f"""
          outbound-host = {self.buildout['request-all-relays']['relay-host']}
          outbound-smtp-port = 10587""")
      has_proxy = dumps(info['addr'] in options['domain-to-proxy-map'])
      section += textwrap.dedent(f"""
        outbound-has-proxy = {has_proxy}""")
    self.buildout.parse(section)
{%- endraw %}

