[buildout]
extends =
  ${monitor2-template:output}
  ${template-logrotate-base:output}
parts =
  cron-entry-logrotate
  directory
  publish-connection-information
  inbound-postfix
  outbound-postfix

eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
# todo: we use same for two since it's behind a port forward anyways
submission-port = $${outbound-postfix-main.cf:submission-port}
smtp-port = $${inbound-postfix-main.cf:smtp-port}
smtp-ipv6 = {{ ipv6 }}
# todo: publishes internal ip instead of external
dns-entries =
  {% for domain in slapparameter_dict['mail-domains'] -%}
  {{ domain['name'] }} MX 10 {{ ipv4 }}
  {% endfor %}

[monitor-instance-parameter]
password = {{ slapparameter_dict['monitor-password'] }}

[directory]
recipe = slapos.cookbook:mkdirectory
home = $${buildout:directory}
etc = $${:home}/etc
var = $${:home}/var
bin = $${:home}/bin
usr = $${:home}/usr
tmp = $${:home}/tmp
run = $${:var}/run
libexec = $${:usr}/libexec
script = $${:etc}/run
service = $${:etc}/service
log = $${:var}/log
var-log = $${:var}/log
var-lib = $${:var}/lib
var-spool = $${:var}/spool
vhosts = $${:home}/vhosts
srv = $${buildout:directory}/srv
postfix-usr = $${:usr}/postfix
postfix-etc = $${:etc}/postfix
postfix-ca-private = $${:postfix-etc}/private
postfix-ca-certs = $${:postfix-etc}/certs

[userinfo]
recipe = slapos.cookbook:userinfo

[postfix-generate-certificate]
recipe  = plone.recipe.command
stop-on-error   = true
key-file    = $${directory:postfix-ca-private}/postfix.key
cert-file   = $${directory:postfix-ca-certs}/postfix.crt
command =
    test -e $${:key-file} || \
        ${openssl:location}/bin/openssl req -newkey rsa -batch -new -sha256 -x509 -days 3650 -nodes   \
        -keyout $${:key-file} -out $${:cert-file}
update-command = $${:command}


# Postfix authentication
# ----------------------

{% set source_host_list = [] %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     do source_host_list.append("[" + domain['mail-server-host'] + "]") %}
{%   endif %}
{% endfor %}

{# Group IP-based sending domains by mail-server-host for per-host sender restrictions #}
{% set sender_host_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     set host = domain['mail-server-host'] %}
{%     if host not in sender_host_domains %}
{%       do sender_host_domains.update({host: []}) %}
{%     endif %}
{%     do sender_host_domains[host].append(domain['name']) %}
{%   endif %}
{% endfor %}
{% set sorted_sender_hosts = sender_host_domains.keys() | sort %}

{# Collect password-authenticated sending domains #}
{% set password_auth_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'password' and domain.get('password') %}
{%     do password_auth_domains.update({domain['name']: domain['password']}) %}
{%   endif %}
{% endfor %}
{% set has_password_auth = password_auth_domains | length > 0 %}


# Postfix macros
# --------------

[macro.postfix-spool-directory]
recipe = slapos.cookbook:mkdirectory
# Not used at buildout level, presence needed by postfix.
spool-active = $${:var-spool}/active
spool-bounce = $${:var-spool}/bounce
spool-corrupt = $${:var-spool}/corrupt
spool-defer = $${:var-spool}/defer
spool-deferred = $${:var-spool}/deferred
spool-flush = $${:var-spool}/flush
spool-hold = $${:var-spool}/hold
spool-incoming = $${:var-spool}/incoming
spool-maildrop = $${:var-spool}/maildrop
spool-pid = $${:var-spool}/pid
spool-private = $${:var-spool}/private
spool-public = $${:var-spool}/public
spool-saved = $${:var-spool}/saved
spool-trace = $${:var-spool}/trace

[macro.postfix-directory]
recipe = slapos.recipe.build
role = $${missing_option_role:error}
impl-section = $${:_buildout_section_name_}-impl
init =
  section = """
  [%(impl-section)s]
  <= macro.postfix-spool-directory
  etc = $${directory:postfix-etc}/%(role)s
  var-lib = $${directory:var-lib}/postfix/%(role)s
  var-spool = $${directory:var-lib}/postfix/%(role)s
  """ % options
  self.buildout.parse(section)
  part = self.buildout[options['impl-section']]
  for opt in part:
    options.setdefault(opt, part[opt])

[macro.postfix-master.cf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_master.jinja2.cf:target}
context =
  key port :port
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}

[macro.postfix-main.cf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_main.jinja2.cf:target}
log-file = $${missing_option_log-file:error}
postfix-directory = $${missing_option_postfix-directory:error}
context =
  section directory directory
  section postfix_directory $${:postfix-directory}
  key content :content
  key mail_owner userinfo:pw-name
  key setgid_group userinfo:gr-name
  raw server_fqdn {{ server_fqdn }}
  raw xz_utils_location ${xz-utils:location}
  raw postfix_location ${postfix:location}
  raw postfix_log_path $${:log-file}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}


# Postfix Transport Information
# -----------------------------

{% set mail_domains = slapparameter_dict['mail-domains'] %}
{% set proxy_host = slapparameter_dict['proxy-host'] %}
{% set proxy_port = slapparameter_dict['proxy-port'] %}

[internal-postfix-transport]
recipe = slapos.recipe.template:jinja2
url = ${postfix_transport.in:target}
output = $${directory:postfix-etc}/transport
context =
  import json_module json
  raw mail_domains {{ json_module.dumps(slapparameter_dict['mail-domains']) }}


# Postfix Inbound SMTP server
# ---------------------------

[inbound-postfix-directory]
<= macro.postfix-directory
role = inbound

[inbound-postfix-master.cf]
<= macro.postfix-master.cf
output = $${inbound-postfix-directory:etc}/master.cf
port = $${inbound-postfix-main.cf:smtp-port}

[inbound-postfix-main.cf]
<= macro.postfix-main.cf
output = $${inbound-postfix-directory:etc}/main.cf
log-file = $${directory:var-log}/inbound_postfix.log
postfix-directory = inbound-postfix-directory
smtp-port = 10025
# submission-port = 10588
content =
  smtp_tls_security_level = none

  smtpd_relay_restrictions =
    permit_mynetworks
    reject_unauth_destination

  mynetworks = [{{ ipv6 }}]/128 {{ ipv4 }} 127.0.0.0/8 {{ (source_host_list) | join(' ') }}

  virtual_transport = relay
  relay_recipient_maps =
  relay_domains = {{ (mail_domains) | map(attribute='name') | join(',') }}

  # TLS parameters
  smtpd_tls_cert_file=$${postfix-generate-certificate:cert-file}
  smtpd_tls_key_file=$${postfix-generate-certificate:key-file}
  smtpd_tls_security_level=may

  smtp_tls_CApath=/etc/ssl/certs
  smtp_tls_session_cache_database = btree:$${inbound-postfix-directory:var-lib}/smtp_scache

  transport_maps = texthash:$${internal-postfix-transport:output}

[inbound-postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
inline =
  #!/bin/sh
  rm -f $${inbound-postfix-directory:spool-pid}/*.pid
  ${postfix:location}/usr/libexec/postfix/master -c $${inbound-postfix-directory:etc}

[inbound-postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${inbound-postfix-wrapper:output}
wrapper-path = $${directory:service}/inbound-postfix
mode = 0775
pidfile = $${directory:run}/inbound_postfix.pid
environment =
  MAIL_CONFIG=$${inbound-postfix-directory:etc}
  SASL_CONF_PATH=$${inbound-postfix-directory:etc}
hash-files =
  $${inbound-postfix-main.cf:output}
  $${inbound-postfix-master.cf:output}
  $${inbound-postfix-wrapper:output}
depends =
  $${inbound-logrotate-entry-postfix:recipe}

[inbound-postfix-smtp-promise]
<= monitor-promise-base
promise = check_socket_listening
name = inbound_smtp_listen.py
config-host = {{ ipv6 }}
config-port = $${inbound-postfix-main.cf:smtp-port}

[inbound-postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${inbound-postfix-service:recipe}
  $${postfix-wrappers:depends}
  $${inbound-postfix-smtp-promise:recipe}

[inbound-logrotate-entry-postfix]
<= logrotate-entry-base
name = inbound_postfix
log = $${inbound-postfix-main.cf:log-file}
copytruncate = true


# Postfix Outbound SMTP server
# ----------------------------

[outbound-postfix-directory]
<= macro.postfix-directory
role = outbound

[outbound-postfix-master.cf]
<= macro.postfix-master.cf
output = $${outbound-postfix-directory:etc}/master.cf
port = $${outbound-postfix-main.cf:submission-port}

[outbound-postfix-main.cf]
<= macro.postfix-main.cf
output = $${outbound-postfix-directory:etc}/main.cf
log-file = $${directory:var-log}/outbound_postfix.log
postfix-directory = outbound-postfix-directory
# smtp-port = 10026
submission-port = 10587
content =
  smtp_tls_security_level = none
  smtp_sasl_auth_enable = yes
  smtp_sasl_security_options = noanonymous
  smtp_sasl_password_maps = texthash:$${outbound-postfix-sasl-passwd:output}

  # smtpd_relay_restrictions =
  #   permit_mynetworks
  #   reject_unauth_destination

  mynetworks = [{{ ipv6 }}]/128 {{ ipv4 }} 127.0.0.0/8 {{ (source_host_list) | join(' ') }}

  virtual_transport = relay
  relay_recipient_maps =
  relay_domains = {{ (mail_domains) | map(attribute='name') | join(',') }}
  relayhost = [{{ proxy_host }}]:{{ proxy_port }}

  # TLS parameters
  smtpd_tls_cert_file=$${postfix-generate-certificate:cert-file}
  smtpd_tls_key_file=$${postfix-generate-certificate:key-file}
  # smtpd_tls_security_level=may
  smtp_tls_CApath=/etc/ssl/certs
  smtp_tls_session_cache_database = btree:$${outbound-postfix-directory:var-lib}/smtp_scache

  transport_maps = texthash:$${internal-postfix-transport:output}

  # Per-host sender domain restrictions
  # Each sending backend is only allowed to use MAIL FROM with its own domains.
  {% set sorted_sender_hosts = sender_host_domains.keys() | sort -%}
  {% if sorted_sender_hosts %}
  smtpd_restriction_classes =
  {%- for host in sorted_sender_hosts %}
    restrict_sender_{{ loop.index }}
  {%- endfor %}

  {% for host in sorted_sender_hosts -%}
  restrict_sender_{{ loop.index }} =
    check_sender_access texthash:$${outbound-postfix-directory:etc}/sender_access_{{ loop.index }}
    reject
  {% endfor %}
  smtpd_sender_restrictions =
    check_client_access cidr:$${outbound-postfix-directory:etc}/client_sender_access
  {% endif %}

  smtpd_sasl_auth_enable=yes
  smtpd_sasl_path=smtpd
  smtpd_sasl_local_domain=relay
  smtpd_sasl_security_options=noanonymous
  smtpd_tls_security_level=encrypt
  smtpd_relay_restrictions=
    permit_mynetworks
    permit_sasl_authenticated
    reject
  smtpd_sender_restrictions=
    reject_sender_login_mismatch
  smtpd_sender_login_maps=texthash:$${outbound-postfix-directory:etc}/sender_login_map

[outbound-postfix-sasl-passwd]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sasl_passwd.in:target}
output = $${outbound-postfix-directory:etc}/sasl_passwd
context =
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  raw proxy_user {{ slapparameter_dict['proxy-user'] }}
  raw proxy_pass {{ slapparameter_dict['proxy-password'] }}

{% for host in sorted_sender_hosts %}
[outbound-postfix-sender-access-{{ loop.index }}]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_access.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_access_{{ loop.index }}
context =
  import json_module json
  raw domains {{ json_module.dumps(sender_host_domains[host]) }}
{% endfor %}
{% if sorted_sender_hosts %}
[outbound-postfix-client-sender-access]
recipe = slapos.recipe.template:jinja2
url = ${postfix_client_sender_access.jinja2:target}
output = $${outbound-postfix-directory:etc}/client_sender_access
context =
  import json_module json
  raw sender_host_domains {{ json_module.dumps(sender_host_domains) }}
{% endif %}

{% if has_password_auth %}
[outbound-postfix-smtpd-sasl-conf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_smtpd_sasl.jinja2.conf:target}
output = $${outbound-postfix-directory:etc}/smtpd.conf
context =
  raw sasldb_path $${outbound-postfix-directory:etc}/sasldb2

[outbound-postfix-sender-login-map]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_login_map.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_login_map
context =
  import json_module json
  raw password_auth_domains {{ json_module.dumps(list(password_auth_domains.keys())) }}

[outbound-postfix-sasldb]
recipe = plone.recipe.command
stop-on-error = true
sasldb-path = $${outbound-postfix-directory:etc}/sasldb2
command =
  rm -f $${:sasldb-path} &&
{%   for domain, password in password_auth_domains.items() %}
  echo '{{ password }}' | ${cyrus-sasl:location}/sbin/saslpasswd2 -f $${:sasldb-path} -p -c -u relay {{ domain }} &&
{%   endfor %}
  echo "sasldb populated"
update-command = $${:command}
{% endif %}

[outbound-postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
inline =
  #!/bin/sh
  rm -f $${outbound-postfix-directory:spool-pid}/*.pid
  ${postfix:location}/usr/libexec/postfix/master -c $${outbound-postfix-directory:etc}

[outbound-postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${outbound-postfix-wrapper:output}
wrapper-path = $${directory:service}/outbound-postfix
mode = 0775
pidfile = $${directory:run}/outbound_postfix.pid
environment =
  MAIL_CONFIG=$${outbound-postfix-directory:etc}
  SASL_CONF_PATH=$${outbound-postfix-directory:etc}
hash-files =
  $${outbound-postfix-main.cf:output}
  $${outbound-postfix-master.cf:output}
  $${outbound-postfix-wrapper:output}
{%- for host in sorted_sender_hosts %}
  $${outbound-postfix-sender-access-{{ loop.index }}:output}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${outbound-postfix-client-sender-access:output}
{%- endif %}
{%- if has_password_auth %}
  $${outbound-postfix-smtpd-sasl-conf:output}
  $${outbound-postfix-sender-login-map:output}
  $${outbound-postfix-sasldb:sasldb-path}
{%- endif %}
depends =
  $${outbound-logrotate-entry-postfix:recipe}
{%- for host in sorted_sender_hosts %}
  $${outbound-postfix-sender-access-{{ loop.index }}:recipe}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${outbound-postfix-client-sender-access:recipe}
{%- endif %}
{%- if has_password_auth %}
  $${outbound-postfix-smtpd-sasl-conf:recipe}
  $${outbound-postfix-sender-login-map:recipe}
  $${outbound-postfix-sasldb:recipe}
{%- endif %}

[outbound-postfix-submission-promise]
<= monitor-promise-base
promise = check_socket_listening
name = outbound_subm_listen.py
config-host = {{ ipv6 }}
config-port = $${outbound-postfix-main.cf:submission-port}

[outbound-postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${outbound-postfix-service:recipe}
  $${postfix-wrappers:depends}
  $${outbound-postfix-submission-promise:recipe}

[outbound-logrotate-entry-postfix]
<= logrotate-entry-base
name = outbound_postfix
log = $${outbound-postfix-main.cf:log-file}
copytruncate = true


# Wrappers
# --------

[base-wrapper]
recipe = slapos.cookbook:wrapper
# environment =
#  MAIL_CONFIG=$${outbound-postfix-directory:etc}
#  SASL_CONF_PATH=$${outbound-postfix-directory:etc}

[base-bin-wrapper]
< = base-wrapper
command-line = $${:path}/$${:basename}
wrapper-path = $${directory:bin}/$${:basename}

[base-bin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/bin

[base-sbin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/sbin

{% set postfix_wrappers = [] -%}
{% for extend, basename_list in (
  (
    'base-bin-bin-wrapper',
    (
      'mailq',
      'newaliases',
    ),
  ),
  (
    'base-sbin-bin-wrapper',
    (
      'postcat',
      'postconf',
      'postdrop',
      'postfix',
      'postkick',
      'postlock',
      'postlog',
      'postmap',
      'postmulti',
      'postqueue',
      'postsuper',
      'sendmail',
    ),
  ),
) %}
{%   for basename in basename_list -%}
{%     do postfix_wrappers.append('wrapper-' ~ basename) -%}
[wrapper-{{ basename }}]
< = {{ extend }}
basename = {{ basename }}
{%   endfor %}
{% endfor %}

[postfix-wrappers]
depends =
{% for postfix_wrapper in postfix_wrappers -%}
  {{ "  $${" + postfix_wrapper + ":recipe}" }}
{% endfor -%}
