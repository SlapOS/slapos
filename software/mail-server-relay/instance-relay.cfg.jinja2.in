[buildout]
extends =
  ${monitor2-template:output}
  ${template-logrotate-base:output}
parts =
  cron-entry-logrotate
  directory
  publish-connection-information
  postfix

eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
# todo: we use same for two since it's behind a port forward anyways
submission-port = $${postfix-conf-main:submission-port}
smtp-port = $${postfix-conf-main:smtp-port}
smtp-ipv6 = {{ ipv6 }}
# todo: publishes internal ip instead of external
dns-entries =
  {% for domain in slapparameter_dict['mail-domains'] -%}
  {{ domain['name'] }} MX 10 {{ ipv4 }}
  {% endfor %}

[directory]
recipe = slapos.cookbook:mkdirectory
home = $${buildout:directory}
etc = $${:home}/etc
var = $${:home}/var
bin = $${:home}/bin
usr = $${:home}/usr
tmp = $${:home}/tmp
run = $${:var}/run
libexec = $${:usr}/libexec
script = $${:etc}/run
service = $${:etc}/service
log = $${:var}/log
var-log = $${:var}/log
var-lib = $${:var}/lib
var-spool = $${:var}/spool
vhosts = $${:home}/vhosts
srv = $${buildout:directory}/srv

[userinfo]
recipe = slapos.cookbook:userinfo

[ethernet-ip]
recipe = slapos.recipe.build
init =
  import netifaces
  for i in netifaces.interfaces():
      if not (i.startswith("slaptun") or i.startswith("re6stnet") or i == "lo"):
          a = netifaces.ifaddresses(i)
          if netifaces.AF_INET in a:
              try:
                  options['ipv4'] = a[netifaces.AF_INET][0]['addr']
              except:
                  options['ipv4'] = "0.0.0.0"


# Postfix SMTP server
# -------------------

[postfix-directory]
recipe = slapos.cookbook:mkdirectory
usr = $${directory:usr}/postfix
etc = $${directory:etc}/postfix
var-lib = $${directory:var-lib}/postfix
var-spool = $${directory:var-spool}/postfix
ca-private = $${:etc}/private
ca-certs = $${:etc}/certs
# Not used at buildout level, presence needed by postfix.
spool-active = $${:var-spool}/active
spool-bounce = $${:var-spool}/bounce
spool-corrupt = $${:var-spool}/corrupt
spool-defer = $${:var-spool}/defer
spool-deferred = $${:var-spool}/deferred
spool-flush = $${:var-spool}/flush
spool-hold = $${:var-spool}/hold
spool-incoming = $${:var-spool}/incoming
spool-maildrop = $${:var-spool}/maildrop
spool-pid = $${:var-spool}/pid
spool-private = $${:var-spool}/private
spool-public = $${:var-spool}/public
spool-saved = $${:var-spool}/saved
spool-trace = $${:var-spool}/trace

{% set source_host_list = [] %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     do source_host_list.append("[" + domain['mail-server-host'] + "]") %}
{%   endif %}
{% endfor %}

{# Group IP-based sending domains by mail-server-host for per-host sender restrictions #}
{% set sender_host_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     set host = domain['mail-server-host'] %}
{%     if host not in sender_host_domains %}
{%       do sender_host_domains.update({host: []}) %}
{%     endif %}
{%     do sender_host_domains[host].append(domain['name']) %}
{%   endif %}
{% endfor %}
{% set sorted_sender_hosts = sender_host_domains.keys() | sort %}

{# Collect password-authenticated sending domains #}
{% set password_auth_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'password' and domain.get('password') %}
{%     do password_auth_domains.update({domain['name']: domain['password']}) %}
{%   endif %}
{% endfor %}
{% set has_password_auth = password_auth_domains | length > 0 %}

[postfix-conf-main]
recipe = slapos.recipe.template:jinja2
url = ${postfix_main.jinja2.cf:target}
output = $${postfix-directory:etc}/main.cf
smtp-port = 10025
submission-port = 10587
mail-domains = {{ dumps(slapparameter_dict['mail-domains']) }}
mail-hosts = {{ dumps(source_host_list) }}
sender-host-domains = {{ dumps(sender_host_domains) }}
password-auth-domains = {{ dumps(password_auth_domains) }}
log-file = $${directory:var-log}/postfix.log
context =
  key bin_directory directory:bin
  key usr_directory postfix-directory:usr
  key queue_directory postfix-directory:var-spool
  key data_directory postfix-directory:var-lib
  key spool_directory postfix-directory:var-spool
  key vhosts_directory directory:vhosts
  key log_directory directory:var-log
  key mail_owner userinfo:pw-name
  key setgid_group userinfo:gr-name
  raw server_fqdn {{ server_fqdn }}
  key sasl_passwd postfix-sasl-passwd:output
  key transport_maps postfix-transport:output
  raw xz_utils_location ${xz-utils:location}
  raw postfix_location ${postfix:location}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  key mail_domains :mail-domains
  key mail_hosts :mail-hosts
  key postfix_cert_file postfix-generate-certificate:cert-file
  key postfix_key_file postfix-generate-certificate:key-file
  raw postfix_log_path $${:log-file}
  key sender_host_domains :sender-host-domains
  raw postfix_etc_directory $${postfix-directory:etc}

[postfix-conf-master]
recipe = slapos.recipe.template:jinja2
url = ${postfix_master.jinja2.cf:target}
output = $${postfix-directory:etc}/master.cf
context =
  key smtp_port postfix-conf-main:smtp-port
  key submission_port postfix-conf-main:submission-port
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw has_password_auth {{ 'true' if has_password_auth else 'false' }}
  raw postfix_etc_directory $${postfix-directory:etc}
  key mail_owner userinfo:pw-name
  raw policyd_spf_bin ${spf-engine:bin-directory}/policyd-spf
  key policyd_spf_conf policyd-spf-conf:output

[postfix-generate-certificate]
recipe  = plone.recipe.command
stop-on-error   = true

key-file    = $${postfix-directory:ca-private}/postfix.key
cert-file   = $${postfix-directory:ca-certs}/postfix.crt

command =
    test -e $${:key-file} || \
        ${openssl:location}/bin/openssl req -newkey rsa -batch -new -sha256 -x509 -days 3650 -nodes   \
        -keyout $${:key-file} -out $${:cert-file}

update-command = $${:command}

[postfix-sasl-passwd]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sasl_passwd.in:target}
output = $${postfix-directory:etc}/sasl_passwd
context =
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  raw proxy_user {{ slapparameter_dict['proxy-user'] }}
  raw proxy_pass {{ slapparameter_dict['proxy-password'] }}

[postfix-transport]
recipe = slapos.recipe.template:jinja2
url = ${postfix_transport.in:target}
output = $${postfix-directory:etc}/transport
context =
  import json_module json
  raw mail_domains {{ json_module.dumps(slapparameter_dict['mail-domains']) }}

{% for host in sorted_sender_hosts %}
[postfix-sender-access-{{ loop.index }}]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_access.jinja2:target}
output = $${postfix-directory:etc}/sender_access_{{ loop.index }}
context =
  import json_module json
  raw domains {{ json_module.dumps(sender_host_domains[host]) }}
{% endfor %}
{% if sorted_sender_hosts %}
[postfix-client-sender-access]
recipe = slapos.recipe.template:jinja2
url = ${postfix_client_sender_access.jinja2:target}
output = $${postfix-directory:etc}/client_sender_access
context =
  import json_module json
  raw sender_host_domains {{ json_module.dumps(sender_host_domains) }}
{% endif %}

{% if has_password_auth %}
[postfix-smtpd-sasl-conf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_smtpd_sasl.jinja2.conf:target}
output = $${postfix-directory:etc}/smtpd.conf
context =
  raw sasldb_path $${postfix-directory:etc}/sasldb2

[postfix-sender-login-map]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_login_map.jinja2:target}
output = $${postfix-directory:etc}/sender_login_map
context =
  import json_module json
  raw password_auth_domains {{ json_module.dumps(list(password_auth_domains.keys())) }}

[postfix-sasldb]
recipe = plone.recipe.command
stop-on-error = true
sasldb-path = $${postfix-directory:etc}/sasldb2
command =
  rm -f $${:sasldb-path} &&
{%   for domain, password in password_auth_domains.items() %}
  echo '{{ password }}' | ${cyrus-sasl:location}/sbin/saslpasswd2 -f $${:sasldb-path} -p -c -u relay {{ domain }} &&
{%   endfor %}
  echo "sasldb populated"
update-command = $${:command}
{% endif %}

[postfix-symlinks-libexec]
recipe = slapos.cookbook:symbolic.link
target-directory = $${postfix-directory:usr}
link-binary =
    ${postfix:location}/usr/libexec

[policyd-spf-conf]
recipe = slapos.recipe.template:jinja2
url = ${policyd_spf.jinja2.conf:target}
output = $${postfix-directory:etc}/policyd-spf.conf
context =

[postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
inline =
  #!/bin/sh
  rm -f var/spool/postfix/pid/*.pid
  $${postfix-directory:usr}/libexec/postfix/master -c $${postfix-directory:etc}

[postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${postfix-wrapper:output}
wrapper-path = $${directory:service}/postfix
mode = 0775
pidfile = $${directory:run}/postfix.pid
environment =
  MAIL_CONFIG=$${postfix-directory:etc}
  SASL_CONF_PATH=$${postfix-directory:etc}
hash-files =
  $${postfix-conf-main:output}
  $${postfix-conf-master:output}
  $${postfix-wrapper:output}
  $${policyd-spf-conf:output}
{%- for host in sorted_sender_hosts %}
  $${postfix-sender-access-{{ loop.index }}:output}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${postfix-client-sender-access:output}
{%- endif %}
{%- if has_password_auth %}
  $${postfix-smtpd-sasl-conf:output}
  $${postfix-sender-login-map:output}
  $${postfix-sasldb:sasldb-path}
{%- endif %}
depends =
  $${postfix-symlinks-libexec:recipe}
  $${policyd-spf-conf:recipe}
  $${logrotate-entry-postfix:recipe}
{%- for host in sorted_sender_hosts %}
  $${postfix-sender-access-{{ loop.index }}:recipe}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${postfix-client-sender-access:recipe}
{%- endif %}
{%- if has_password_auth %}
  $${postfix-smtpd-sasl-conf:recipe}
  $${postfix-sender-login-map:recipe}
  $${postfix-sasldb:recipe}
{%- endif %}

[postfix-service-master]
< = base-wrapper
command-line = $${directory:usr}/libexec/postfix/master -c $${postfix-directory:etc}
wrapper-path = $${directory:run}/postfix-master

{% if has_password_auth %}
[postfix-submission-promise]
<= monitor-promise-base
promise = check_socket_listening
name = subm_listen.py
config-host = {{ ipv6 }}
config-port = $${postfix-conf-main:submission-port}
{% endif %}

[postfix-smtp-promise]
<= monitor-promise-base
promise = check_socket_listening
name = smtp_listen.py
config-host = {{ ipv6 }}
config-port = $${postfix-conf-main:smtp-port}

[postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${postfix-service:recipe}
  $${postfix-service-master:recipe}
  $${postfix-wrappers:depends}
{%- if has_password_auth %}
  $${postfix-submission-promise:recipe}
{%- endif %}
  $${postfix-smtp-promise:recipe}

[base-wrapper]
recipe = slapos.cookbook:wrapper
environment =
  MAIL_CONFIG=$${postfix-directory:etc}
  SASL_CONF_PATH=$${postfix-directory:etc}

[base-bin-wrapper]
< = base-wrapper
command-line = $${:path}/$${:basename}
wrapper-path = $${directory:bin}/$${:basename}

[base-bin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/bin

[base-sbin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/sbin

{% set postfix_wrappers = [] -%}
{% for extend, basename_list in (
  (
    'base-bin-bin-wrapper',
    (
      'mailq',
      'newaliases',
    ),
  ),
  (
    'base-sbin-bin-wrapper',
    (
      'postcat',
      'postconf',
      'postdrop',
      'postfix',
      'postkick',
      'postlock',
      'postlog',
      'postmap',
      'postmulti',
      'postqueue',
      'postsuper',
      'sendmail',
    ),
  ),
) %}
{%   for basename in basename_list -%}
{%     do postfix_wrappers.append('wrapper-' ~ basename) -%}
[wrapper-{{ basename }}]
< = {{ extend }}
basename = {{ basename }}
{%   endfor %}
{% endfor %}

[postfix-wrappers]
depends =
{% for postfix_wrapper in postfix_wrappers -%}
  {{ "  $${" + postfix_wrapper + ":recipe}" }}
{% endfor -%}

[logrotate-entry-postfix]
<= logrotate-entry-base
name = postfix
log = $${postfix-conf-main:log-file}
copytruncate = true

[monitor-instance-parameter]
password = {{ slapparameter_dict['monitor-password'] }}
