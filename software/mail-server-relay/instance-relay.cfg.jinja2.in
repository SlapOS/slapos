url = ${postfix_sender_access.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_access_{{ loop.index }}
context =
  import json_module json
  raw domains {{ json_module.dumps(sender_host_domains[host]) }}
{% endfor %}
{% if sorted_sender_hosts %}
[outbound-postfix-client-sender-access]
recipe = slapos.recipe.template:jinja2
url = ${postfix_client_sender_access.jinja2:target}
output = $${outbound-postfix-directory:etc}/client_sender_access
context =
  import json_module json
  raw sender_host_domains {{ json_module.dumps(sender_host_domains) }}
{% endif %}

{% if has_password_auth %}
[outbound-postfix-smtpd-sasl-conf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_smtpd_sasl.jinja2.conf:target}
output = $${outbound-postfix-directory:etc}/smtpd.conf
context =
  raw sasldb_path $${outbound-postfix-directory:etc}/sasldb2

[outbound-postfix-sender-login-map]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_login_map.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_login_map
context =
  import json_module json
  raw password_auth_domains {{ json_module.dumps(list(password_auth_domains.keys())) }}

[outbound-postfix-sasldb]
recipe = plone.recipe.command
stop-on-error = true
sasldb-path = $${outbound-postfix-directory:etc}/sasldb2
command =
  rm -f $${:sasldb-path} &&
{%   for domain, password in password_auth_domains.items() %}
  echo '{{ password }}' | ${cyrus-sasl:location}/sbin/saslpasswd2 -f $${:sasldb-path} -p -c -u relay {{ domain }} &&
{%   endfor %}
  echo "sasldb populated"
update-command = $${:command}
{% endif %}

[outbound-postfix-symlinks-libexec]
recipe = slapos.cookbook:symbolic.link
target-directory = $${outbound-postfix-directory:usr}
link-binary =
    ${postfix:location}/usr/libexec

[outbound-postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
inline =
  #!/bin/sh
  rm -f $${outbound-postfix-directory:spool-pid}/*.pid
  $${outbound-postfix-directory:usr}/libexec/postfix/master -c $${outbound-postfix-directory:etc}

[outbound-postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${outbound-postfix-wrapper:output}
wrapper-path = $${directory:service}/outbound-postfix
mode = 0775
pidfile = $${directory:run}/outbound_postfix.pid
environment =
  MAIL_CONFIG=$${outbound-postfix-directory:etc}
  SASL_CONF_PATH=$${outbound-postfix-directory:etc}
hash-files =
  $${outbound-postfix-conf-main:output}
  $${outbound-postfix-conf-master:output}
  $${outbound-postfix-wrapper:output}
{%- for host in sorted_sender_hosts %}
  $${outbound-postfix-sender-access-{{ loop.index }}:output}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${outbound-postfix-client-sender-access:output}
{%- endif %}
{%- if has_password_auth %}
  $${outbound-postfix-smtpd-sasl-conf:output}
  $${outbound-postfix-sender-login-map:output}
  $${outbound-postfix-sasldb:sasldb-path}
{%- endif %}
depends =
  $${outbound-postfix-symlinks-libexec:recipe}
  $${outbound-logrotate-entry-postfix:recipe}
{%- for host in sorted_sender_hosts %}
  $${outbound-postfix-sender-access-{{ loop.index }}:recipe}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${outbound-postfix-client-sender-access:recipe}
{%- endif %}
{%- if has_password_auth %}
  $${outbound-postfix-smtpd-sasl-conf:recipe}
  $${outbound-postfix-sender-login-map:recipe}
  $${outbound-postfix-sasldb:recipe}
{%- endif %}

{% if has_password_auth %}
[outbound-postfix-submission-promise]
<= monitor-promise-base
promise = check_socket_listening
name = outbound_subm_listen.py
config-host = {{ ipv6 }}
config-port = $${outbound-postfix-conf-main:submission-port}
{% endif %}

[outbound-postfix-smtp-promise]
<= monitor-promise-base
promise = check_socket_listening
name = outbound_smtp_listen.py
config-host = {{ ipv6 }}
config-port = $${outbound-postfix-conf-main:smtp-port}

[outbound-postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${outbound-postfix-service:recipe}
  $${postfix-wrappers:depends}
{%- if has_password_auth %}
  $${outbound-postfix-submission-promise:recipe}
{%- endif %}
  $${outbound-postfix-smtp-promise:recipe}

[outbound-logrotate-entry-postfix]
<= logrotate-entry-base
name = outbound_postfix
log = $${outbound-postfix-conf-main:log-file}
copytruncate = true


# Wrappers
# --------

[base-wrapper]
recipe = slapos.cookbook:wrapper
# environment =
#  MAIL_CONFIG=$${outbound-postfix-directory:etc}
#  SASL_CONF_PATH=$${outbound-postfix-directory:etc}

[base-bin-wrapper]
< = base-wrapper
command-line = $${:path}/$${:basename}
wrapper-path = $${directory:bin}/$${:basename}

[base-bin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/bin

[base-sbin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/sbin

{% set postfix_wrappers = [] -%}
{% for extend, basename_list in (
  (
    'base-bin-bin-wrapper',
    (
      'mailq',
      'newaliases',
    ),
  ),
  (
    'base-sbin-bin-wrapper',
    (
      'postcat',
      'postconf',
      'postdrop',
      'postfix',
      'postkick',
      'postlock',
      'postlog',
      'postmap',
      'postmulti',
      'postqueue',
      'postsuper',
      'sendmail',
    ),
  ),
) %}
{%   for basename in basename_list -%}
{%     do postfix_wrappers.append('wrapper-' ~ basename) -%}
[wrapper-{{ basename }}]
< = {{ extend }}
basename = {{ basename }}
{%   endfor %}
{% endfor %}

[postfix-wrappers]
depends =
{% for postfix_wrapper in postfix_wrappers -%}
  {{ "  $${" + postfix_wrapper + ":recipe}" }}
{% endfor -%}
