[buildout]
extends =
  ${monitor2-template:output}
  ${template-logrotate-base:output}
parts =
  cron-entry-logrotate
  directory
  publish-connection-information
  inbound-postfix
  outbound-postfix

eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
# todo: we use same for two since it's behind a port forward anyways
submission-port = $${outbound-postfix-conf-main:submission-port}
smtp-port = $${inbound-postfix-conf-main:smtp-port}
smtp-ipv6 = {{ ipv6 }}
# todo: publishes internal ip instead of external
dns-entries =
  {% for domain in slapparameter_dict['mail-domains'] -%}
  {{ domain['name'] }} MX 10 {{ ipv4 }}
  {% endfor %}

[monitor-instance-parameter]
password = {{ slapparameter_dict['monitor-password'] }}

[directory]
recipe = slapos.cookbook:mkdirectory
home = $${buildout:directory}
etc = $${:home}/etc
var = $${:home}/var
bin = $${:home}/bin
usr = $${:home}/usr
tmp = $${:home}/tmp
run = $${:var}/run
libexec = $${:usr}/libexec
script = $${:etc}/run
service = $${:etc}/service
log = $${:var}/log
var-log = $${:var}/log
var-lib = $${:var}/lib
var-spool = $${:var}/spool
vhosts = $${:home}/vhosts
srv = $${buildout:directory}/srv
postfix-usr = $${:usr}/postfix
postfix-etc = $${:etc}/postfix
postfix-ca-private = $${:postfix-etc}/private
postfix-ca-certs = $${:postfix-etc}/certs

[userinfo]
recipe = slapos.cookbook:userinfo

[postfix-generate-certificate]
recipe  = plone.recipe.command
stop-on-error   = true
key-file    = $${directory:postfix-ca-private}/postfix.key
cert-file   = $${directory:postfix-ca-certs}/postfix.crt
command =
    test -e $${:key-file} || \
        ${openssl:location}/bin/openssl req -newkey rsa -batch -new -sha256 -x509 -days 3650 -nodes   \
        -keyout $${:key-file} -out $${:cert-file}
update-command = $${:command}


# Postfix SMTP server
# -------------------

[inbound-postfix-directory]
recipe = slapos.cookbook:mkdirectory
usr = $${directory:postfix-usr}/inbound
etc = $${directory:postfix-etc}/inbound
var-lib = $${directory:var-lib}/postfix/inbound
var-spool = $${directory:var-spool}/postfix/inbound
# Not used at buildout level, presence needed by postfix.
spool-active = $${:var-spool}/active
spool-bounce = $${:var-spool}/bounce
spool-corrupt = $${:var-spool}/corrupt
spool-defer = $${:var-spool}/defer
spool-deferred = $${:var-spool}/deferred
spool-flush = $${:var-spool}/flush
spool-hold = $${:var-spool}/hold
spool-incoming = $${:var-spool}/incoming
spool-maildrop = $${:var-spool}/maildrop
spool-pid = $${:var-spool}/pid
spool-private = $${:var-spool}/private
spool-public = $${:var-spool}/public
spool-saved = $${:var-spool}/saved
spool-trace = $${:var-spool}/trace

{% set source_host_list = [] %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     do source_host_list.append("[" + domain['mail-server-host'] + "]") %}
{%   endif %}
{% endfor %}

{# Group IP-based sending domains by mail-server-host for per-host sender restrictions #}
{% set sender_host_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     set host = domain['mail-server-host'] %}
{%     if host not in sender_host_domains %}
{%       do sender_host_domains.update({host: []}) %}
{%     endif %}
{%     do sender_host_domains[host].append(domain['name']) %}
{%   endif %}
{% endfor %}
{% set sorted_sender_hosts = sender_host_domains.keys() | sort %}

{# Collect password-authenticated sending domains #}
{% set password_auth_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'password' and domain.get('password') %}
{%     do password_auth_domains.update({domain['name']: domain['password']}) %}
{%   endif %}
{% endfor %}
{% set has_password_auth = password_auth_domains | length > 0 %}

[inbound-postfix-conf-main]
recipe = slapos.recipe.template:jinja2
url = ${postfix_main.jinja2.cf:target}
output = $${inbound-postfix-directory:etc}/main.cf
smtp-port = 10025
submission-port = 10588
mail-domains = {{ dumps(slapparameter_dict['mail-domains']) }}
mail-hosts = {{ dumps(source_host_list) }}
sender-host-domains = {{ dumps(sender_host_domains) }}
password-auth-domains = {{ dumps(password_auth_domains) }}
log-file = $${directory:var-log}/inbound_postfix.log
context =
  key bin_directory directory:bin
  key usr_directory inbound-postfix-directory:usr
  key queue_directory inbound-postfix-directory:var-spool
  key data_directory inbound-postfix-directory:var-lib
  key spool_directory inbound-postfix-directory:var-spool
  key vhosts_directory directory:vhosts
  key log_directory directory:var-log
  key mail_owner userinfo:pw-name
  key setgid_group userinfo:gr-name
  raw server_fqdn {{ server_fqdn }}
  key sasl_passwd inbound-postfix-sasl-passwd:output
  key transport_maps inbound-postfix-transport:output
  raw xz_utils_location ${xz-utils:location}
  raw postfix_location ${postfix:location}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  key mail_domains :mail-domains
  key mail_hosts :mail-hosts
  key postfix_cert_file postfix-generate-certificate:cert-file
  key postfix_key_file postfix-generate-certificate:key-file
  raw postfix_log_path $${:log-file}
  key sender_host_domains :sender-host-domains
  raw postfix_etc_directory $${inbound-postfix-directory:etc}

[inbound-postfix-conf-master]
recipe = slapos.recipe.template:jinja2
url = ${postfix_master.jinja2.cf:target}
output = $${inbound-postfix-directory:etc}/master.cf
context =
  key smtp_port inbound-postfix-conf-main:smtp-port
  key submission_port inbound-postfix-conf-main:submission-port
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw has_password_auth {{ 'true' if has_password_auth else 'false' }}
  raw postfix_etc_directory $${inbound-postfix-directory:etc}

[inbound-postfix-sasl-passwd]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sasl_passwd.in:target}
output = $${inbound-postfix-directory:etc}/sasl_passwd
context =
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  raw proxy_user {{ slapparameter_dict['proxy-user'] }}
  raw proxy_pass {{ slapparameter_dict['proxy-password'] }}

[inbound-postfix-transport]
recipe = slapos.recipe.template:jinja2
url = ${postfix_transport.in:target}
output = $${inbound-postfix-directory:etc}/transport
context =
  import json_module json
  raw mail_domains {{ json_module.dumps(slapparameter_dict['mail-domains']) }}

{% for host in sorted_sender_hosts %}
[inbound-postfix-sender-access-{{ loop.index }}]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_access.jinja2:target}
output = $${inbound-postfix-directory:etc}/sender_access_{{ loop.index }}
context =
  import json_module json
  raw domains {{ json_module.dumps(sender_host_domains[host]) }}
{% endfor %}
{% if sorted_sender_hosts %}
[inbound-postfix-client-sender-access]
recipe = slapos.recipe.template:jinja2
url = ${postfix_client_sender_access.jinja2:target}
output = $${inbound-postfix-directory:etc}/client_sender_access
context =
  import json_module json
  raw sender_host_domains {{ json_module.dumps(sender_host_domains) }}
{% endif %}

{% if has_password_auth %}
[inbound-postfix-smtpd-sasl-conf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_smtpd_sasl.jinja2.conf:target}
output = $${inbound-postfix-directory:etc}/smtpd.conf
context =
  raw sasldb_path $${inbound-postfix-directory:etc}/sasldb2

[inbound-postfix-sender-login-map]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_login_map.jinja2:target}
output = $${inbound-postfix-directory:etc}/sender_login_map
context =
  import json_module json
  raw password_auth_domains {{ json_module.dumps(list(password_auth_domains.keys())) }}

[inbound-postfix-sasldb]
recipe = plone.recipe.command
stop-on-error = true
sasldb-path = $${inbound-postfix-directory:etc}/sasldb2
command =
  rm -f $${:sasldb-path} &&
{%   for domain, password in password_auth_domains.items() %}
  echo '{{ password }}' | ${cyrus-sasl:location}/sbin/saslpasswd2 -f $${:sasldb-path} -p -c -u relay {{ domain }} &&
{%   endfor %}
  echo "sasldb populated"
update-command = $${:command}
{% endif %}

[inbound-postfix-symlinks-libexec]
recipe = slapos.cookbook:symbolic.link
target-directory = $${inbound-postfix-directory:usr}
link-binary =
    ${postfix:location}/usr/libexec

[inbound-postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
inline =
  #!/bin/sh
  rm -f $${inbound-postfix-directory:spool-pid}/*.pid
  $${inbound-postfix-directory:usr}/libexec/postfix/master -c $${inbound-postfix-directory:etc}

[inbound-postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${inbound-postfix-wrapper:output}
wrapper-path = $${directory:service}/inbound-postfix
mode = 0775
pidfile = $${directory:run}/inbound_postfix.pid
environment =
  MAIL_CONFIG=$${inbound-postfix-directory:etc}
  SASL_CONF_PATH=$${inbound-postfix-directory:etc}
hash-files =
  $${inbound-postfix-conf-main:output}
  $${inbound-postfix-conf-master:output}
  $${inbound-postfix-wrapper:output}
{%- for host in sorted_sender_hosts %}
  $${inbound-postfix-sender-access-{{ loop.index }}:output}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${inbound-postfix-client-sender-access:output}
{%- endif %}
{%- if has_password_auth %}
  $${inbound-postfix-smtpd-sasl-conf:output}
  $${inbound-postfix-sender-login-map:output}
  $${inbound-postfix-sasldb:sasldb-path}
{%- endif %}
depends =
  $${inbound-postfix-symlinks-libexec:recipe}
  $${inbound-logrotate-entry-postfix:recipe}
{%- for host in sorted_sender_hosts %}
  $${inbound-postfix-sender-access-{{ loop.index }}:recipe}
{%- endfor %}
{%- if sorted_sender_hosts %}
  $${inbound-postfix-client-sender-access:recipe}
{%- endif %}
{%- if has_password_auth %}
  $${inbound-postfix-smtpd-sasl-conf:recipe}
  $${inbound-postfix-sender-login-map:recipe}
  $${inbound-postfix-sasldb:recipe}
{%- endif %}

{% if has_password_auth %}
[inbound-postfix-submission-promise]
<= monitor-promise-base
promise = check_socket_listening
name = inbound_subm_listen.py
config-host = {{ ipv6 }}
config-port = $${inbound-postfix-conf-main:submission-port}
{% endif %}

[inbound-postfix-smtp-promise]
<= monitor-promise-base
promise = check_socket_listening
name = inbound_smtp_listen.py
config-host = {{ ipv6 }}
config-port = $${inbound-postfix-conf-main:smtp-port}

[inbound-postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${inbound-postfix-service:recipe}
  $${postfix-wrappers:depends}
{%- if has_password_auth %}
  $${inbound-postfix-submission-promise:recipe}
{%- endif %}
  $${inbound-postfix-smtp-promise:recipe}

[inbound-logrotate-entry-postfix]
<= logrotate-entry-base
name = inbound_postfix
log = $${inbound-postfix-conf-main:log-file}
copytruncate = true


# Postfix Outbound SMTP server
# ----------------------------

[outbound-postfix-directory]
recipe = slapos.cookbook:mkdirectory
usr = $${directory:postfix-usr}/outbound
etc = $${directory:postfix-etc}/outbound
var-lib = $${directory:var-lib}/postfix/outbound
var-spool = $${directory:var-spool}/postfix/outbound
ca-private = $${:etc}/private
ca-certs = $${:etc}/certs
# Not used at buildout level, presence needed by postfix.
spool-active = $${:var-spool}/active
spool-bounce = $${:var-spool}/bounce
spool-corrupt = $${:var-spool}/corrupt
spool-defer = $${:var-spool}/defer
spool-deferred = $${:var-spool}/deferred
spool-flush = $${:var-spool}/flush
spool-hold = $${:var-spool}/hold
spool-incoming = $${:var-spool}/incoming
spool-maildrop = $${:var-spool}/maildrop
spool-pid = $${:var-spool}/pid
spool-private = $${:var-spool}/private
spool-public = $${:var-spool}/public
spool-saved = $${:var-spool}/saved
spool-trace = $${:var-spool}/trace

{% set source_host_list = [] %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     do source_host_list.append("[" + domain['mail-server-host'] + "]") %}
{%   endif %}
{% endfor %}

{# Group IP-based sending domains by mail-server-host for per-host sender restrictions #}
{% set sender_host_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'none' %}
{%     set host = domain['mail-server-host'] %}
{%     if host not in sender_host_domains %}
{%       do sender_host_domains.update({host: []}) %}
{%     endif %}
{%     do sender_host_domains[host].append(domain['name']) %}
{%   endif %}
{% endfor %}
{% set sorted_sender_hosts = sender_host_domains.keys() | sort %}

{# Collect password-authenticated sending domains #}
{% set password_auth_domains = {} %}
{% for domain in slapparameter_dict['mail-domains'] | selectattr('can-send', 'equalto', true) %}
{%   if domain.get('authentication', 'none') == 'password' and domain.get('password') %}
{%     do password_auth_domains.update({domain['name']: domain['password']}) %}
{%   endif %}
{% endfor %}
{% set has_password_auth = password_auth_domains | length > 0 %}

[outbound-postfix-conf-main]
recipe = slapos.recipe.template:jinja2
url = ${postfix_main.jinja2.cf:target}
output = $${outbound-postfix-directory:etc}/main.cf
smtp-port = 10026
submission-port = 10587
mail-domains = {{ dumps(slapparameter_dict['mail-domains']) }}
mail-hosts = {{ dumps(source_host_list) }}
sender-host-domains = {{ dumps(sender_host_domains) }}
password-auth-domains = {{ dumps(password_auth_domains) }}
log-file = $${directory:var-log}/outbound_postfix.log
context =
  key bin_directory directory:bin
  key usr_directory outbound-postfix-directory:usr
  key queue_directory outbound-postfix-directory:var-spool
  key data_directory outbound-postfix-directory:var-lib
  key spool_directory outbound-postfix-directory:var-spool
  key vhosts_directory directory:vhosts
  key log_directory directory:var-log
  key mail_owner userinfo:pw-name
  key setgid_group userinfo:gr-name
  raw server_fqdn {{ server_fqdn }}
  key sasl_passwd outbound-postfix-sasl-passwd:output
  key transport_maps outbound-postfix-transport:output
  raw xz_utils_location ${xz-utils:location}
  raw postfix_location ${postfix:location}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  key mail_domains :mail-domains
  key mail_hosts :mail-hosts
  key postfix_cert_file postfix-generate-certificate:cert-file
  key postfix_key_file postfix-generate-certificate:key-file
  raw postfix_log_path $${:log-file}
  key sender_host_domains :sender-host-domains
  raw postfix_etc_directory $${outbound-postfix-directory:etc}

[outbound-postfix-conf-master]
recipe = slapos.recipe.template:jinja2
url = ${postfix_master.jinja2.cf:target}
output = $${outbound-postfix-directory:etc}/master.cf
context =
  key smtp_port outbound-postfix-conf-main:smtp-port
  key submission_port outbound-postfix-conf-main:submission-port
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw has_password_auth {{ 'true' if has_password_auth else 'false' }}
  raw postfix_etc_directory $${outbound-postfix-directory:etc}

[outbound-postfix-sasl-passwd]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sasl_passwd.in:target}
output = $${outbound-postfix-directory:etc}/sasl_passwd
context =
  raw proxy_host {{ slapparameter_dict['proxy-host'] }}
  raw proxy_port {{ slapparameter_dict['proxy-port'] }}
  raw proxy_user {{ slapparameter_dict['proxy-user'] }}
  raw proxy_pass {{ slapparameter_dict['proxy-password'] }}

[outbound-postfix-transport]
recipe = slapos.recipe.template:jinja2
url = ${postfix_transport.in:target}
output = $${outbound-postfix-directory:etc}/transport
context =
  import json_module json
  raw mail_domains {{ json_module.dumps(slapparameter_dict['mail-domains']) }}

