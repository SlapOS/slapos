[buildout]
extends =
  ${monitor2-template:output}
  ${template-logrotate-base:output}
eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true
parts =
  cron-entry-logrotate
  directory
  publish-connection-information
  inbound-postfix
  outbound-postfix
  postfix-certificate-rotation

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
smtp-port = $${inbound-postfix-main.cf:smtp-port}
submission-port = $${outbound-postfix-main.cf:submission-port}
smtp-ipv6 = {{ ipv6 }}
# todo: publishes internal ip instead of external
dns-entries =
  {% for domain in slapparameter_dict['mail-domains'] -%}
  {{ domain['name'] }} MX 10 {{ ipv4 }}
  {% endfor %}
tls-fingerprints = $${postfix-certificate:tls-fingerprints}

[monitor-instance-parameter]
password = {{ slapparameter_dict['monitor-password'] }}

[directory]
recipe = slapos.cookbook:mkdirectory
home = $${buildout:directory}
etc = $${:home}/etc
var = $${:home}/var
bin = $${:home}/bin
usr = $${:home}/usr
tmp = $${:home}/tmp
run = $${:var}/run
libexec = $${:usr}/libexec
script = $${:etc}/run
service = $${:etc}/service
log = $${:var}/log
var-log = $${:var}/log
var-lib = $${:var}/lib
var-spool = $${:var}/spool
vhosts = $${:home}/vhosts
srv = $${buildout:directory}/srv
postfix-usr = $${:usr}/postfix
postfix-etc = $${:etc}/postfix
postfix-ssl = $${:postfix-etc}/ssl

[postgrey-directory]
recipe = slapos.cookbook:mkdirectory
data = $${directory:var-lib}/postgrey

[userinfo]
recipe = slapos.cookbook:userinfo


# Postfix Relay Certificates
# --------------------------

[postfix-certificate]
recipe = slapos.recipe.build
ssl = $${directory:postfix-ssl}
make-cert = ${certificate-make-new:output}
to-der = ${certificate-to-der:output}
name = postfix
init =
  import os, subprocess
  # Inputs
  ssl = options['ssl']
  make_cert = options['make-cert']
  to_der = options['to-der']
  prefix = os.path.join(ssl, options['name'])
  prefixes = prefix, prefix + '.next'
  bundle, next_bundle = (p + '.bundle.pem' for p in prefixes)
  fingerprint, next_fingerprint = (p + '.fingerprint' for p in prefixes)
  der = prefix + '.der'
  # Certificate initialization or rotation
  # Rotation is requested periodically by deleting the current fingerprint
  if not os.path.exists(fingerprint):
    if os.path.exists(next_fingerprint):
      # Rotate
      os.replace(next_bundle, bundle)
      os.replace(next_fingerprint, fingerprint)
    elif not os.path.exists(bundle):
      # Initialize
      os.makedirs(ssl, 0o0777, exist_ok=True) # like slapos.recipe.mkdirectory
      subprocess.check_call((make_cert, bundle, fingerprint))
    else: # BBB if os.path.exists(bundle)
      # BBB: rename pre-upgrade fingerprint file
      os.replace(prefix + '.digest', fingerprint)
    # Convert current certificate to DER
    subprocess.check_call((to_der, bundle, der))
    # Create next certificate
    subprocess.check_call((make_cert, next_bundle, next_fingerprint))
  # Outputs
  options['bundle'] = bundle
  options['fingerprint'] = fingerprint
  options['der'] = der
  tls_fingerprints = []
  for path in (fingerprint, next_fingerprint):
    with open(path) as f:
      tls_fingerprints.append(f.read().split('=', 1)[1].strip())
  options['tls-fingerprints'] = tls_fingerprints

[postfix-certificate-rotate]
recipe = slapos.recipe.template:jinja2
output = $${buildout:bin-directory}/$${:_buildout_section_name_}
context =
  import json json
  section options slap-connection
{% raw -%}
inline =
  #!/bin/sh -e
  rm -f $${postfix-certificate:fingerprint}
  ${slapos-partition-bang:bang} \
    {{ repr(json.dumps(options)) }} \
    'certificate rotation'
{%- endraw %}

[postfix-certificate-rotation]
recipe = slapos.cookbook:cron.d
name = $${:_buildout_section_name_}
cron-entries = $${cron:cron-entries}
time = weekly
command = $${postfix-certificate-rotate:output}
depends = $${cron-service:recipe}


# Postfix macros
# --------------

[macro.postfix-spool-directory]
recipe = slapos.cookbook:mkdirectory
# Not used at buildout level, presence needed by postfix.
spool-active = $${:var-spool}/active
spool-bounce = $${:var-spool}/bounce
spool-corrupt = $${:var-spool}/corrupt
spool-defer = $${:var-spool}/defer
spool-deferred = $${:var-spool}/deferred
spool-flush = $${:var-spool}/flush
spool-hold = $${:var-spool}/hold
spool-incoming = $${:var-spool}/incoming
spool-maildrop = $${:var-spool}/maildrop
spool-pid = $${:var-spool}/pid
spool-private = $${:var-spool}/private
spool-public = $${:var-spool}/public
spool-saved = $${:var-spool}/saved
spool-trace = $${:var-spool}/trace

[macro.postfix-directory]
recipe = slapos.recipe.build
role = $${missing_option_role:error}
impl-section = $${:_buildout_section_name_}-impl
init =
  section = """
  [%(impl-section)s]
  <= macro.postfix-spool-directory
  etc = $${directory:postfix-etc}/%(role)s
  ssl = $${directory:postfix-etc}/%(role)s/ssl
  var-lib = $${directory:var-lib}/postfix/%(role)s
  var-spool = $${directory:var-lib}/postfix/%(role)s
  """ % options
  self.buildout.parse(section)
  part = self.buildout[options['impl-section']]
  for opt in part:
    options.setdefault(opt, part[opt])

[macro.postfix-master.cf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_master.jinja2.cf:target}
content =
context =
  key content :content
  key port :port
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}

[macro.postfix-main.cf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_main.jinja2.cf:target}
log-file = $${missing_option_log-file:error}
postfix-directory = $${missing_option_postfix-directory:error}
fqdn = {{ dumps(slapparameter_dict.get('fqdn', instance_title)) }}
context =
  section directory directory
  section postfix_directory $${:postfix-directory}
  key content :content
  key mail_owner userinfo:pw-name
  key setgid_group userinfo:gr-name
  key server_fqdn :fqdn
  raw xz_utils_location ${xz-utils:location}
  raw postfix_location ${postfix:location}
  raw postfix_log_path $${:log-file}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}

[macro.postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
etc = $${missing_option_etc:error}
spool-pid = $${missing_option_spool-pid:error}
inline =
  #!/bin/sh
  # use postconf to produce a log in case of broken configuration
  ${postfix:location}/usr/sbin/postconf -c $${:etc} > /dev/null
  # remove old pidfiles
  rm -f $${:spool-pid}/*.pid
  # launch postfix
  ${postfix:location}/usr/libexec/postfix/master -c $${:etc}

[macro.postfix-shell-env]
recipe = slapos.recipe.template
output = $${directory:bin}/activate-$${:role}
etc = $${missing_option_etc:error}
role = $${missing_option_role:error}
inline =
  if ! type deactivate > /dev/null 2>&1
  then
    _OLD_PATH=$PATH
    _OLD_PS1=$PS1
    deactivate () {
      PATH=$_OLD_PATH
      PS1=$_OLD_PS1
      unset _OLD_PATH
      unset _OLD_PS1
      unset MAIL_CONFIG
      unset SASL_CONF_PATH
      unset -f deactivate
    }
  fi
  export MAIL_CONFIG=$${:etc}
  export SASL_CONF_PATH=$${:etc}
  export PATH=$${directory:bin}:${postfix:location}/sbin:$_OLD_PATH
  export PS1="($${:role}) $_OLD_PS1"


# Postfix Transport Information
# -----------------------------

{% set mail_domains = slapparameter_dict['mail-domains'] %}
{% set cluster_fqdns = slapparameter_dict['cluster-fqdns'] %}
{% set proxy_map = slapparameter_dict['proxy-map'] %}
{% set greylisting = slapparameter_dict['greylisting'] %}
{% set greylisting_enable = greylisting['enable'] %}
{% set greylisting_delay = greylisting['greylisting-delay'] %}

[internal-postfix-transport]
recipe = slapos.recipe.template:jinja2
url = ${postfix_transport.in:target}
output = $${directory:postfix-etc}/transport
context =
  import json_module json
  raw mail_domains {{ json_module.dumps(mail_domains) }}


# Postfix Inbound SMTP server
# ---------------------------

[inbound-postfix-directory]
<= macro.postfix-directory
role = inbound

[inbound-postfix-shell-env]
<= macro.postfix-shell-env
etc = $${inbound-postfix-directory:etc}
role = inbound

[inbound-postfix-master.cf]
<= macro.postfix-master.cf
output = $${inbound-postfix-directory:etc}/master.cf
port = $${inbound-postfix-main.cf:smtp-port}
content =
  policyd-spf  unix  -       n       n       -       0       spawn
    user=$${userinfo:pw-name} argv=${spf-engine:bin-directory}/policyd-spf $${policyd-spf-conf:output}

{% set custom_inbound_certificate = slapparameter_dict.get('custom-inbound-certificate') -%}

{% if custom_inbound_certificate -%}
[inbound-custom-certificate-bundle]
recipe = slapos.recipe.template
output = $${inbound-postfix-directory:ssl}/custom.bundle.pem
inline ={{ custom_inbound_certificate | indent }}
{% endif %}

[inbound-postfix-certificate]
recipe = slapos.recipe.build
bundle = $${inbound-postfix-directory:ssl}/postfix-inbound.bundle.pem
# Always install self-signed cert, even when inbound uses custom cert
self-signed-bundle = $${postfix-certificate:bundle}
{% if custom_inbound_certificate -%}
selected-bundle = $${inbound-custom-certificate-bundle:output}
{% else -%}
selected-bundle = $${:self-signed-bundle}
{% endif %}
init = options['location'] = ''
install =
  import os
  import shutil
  shutil.copyfile(options['selected-bundle'], options['bundle'] + '.tmp')
  os.replace(options['bundle'] + '.tmp', options['bundle'])

[inbound-postfix-main.cf]
<= macro.postfix-main.cf
output = $${inbound-postfix-directory:etc}/main.cf
log-file = $${directory:var-log}/inbound_postfix.log
postfix-directory = inbound-postfix-directory
smtp-port = 10025
content =
  smtpd_relay_restrictions =
    reject_unauth_destination

  mynetworks = [{{ ipv6 }}]/128 {{ ipv4 }} 127.0.0.0/8

  # Custom restriction classes
  smtpd_restriction_classes =
    spf_passed

  spf_passed =
    permit

  # Inbound relay access

  # Disable Delivery Status Notifications
  # See https://www.postfix.org/DSN_README.html
  smtpd_discard_ehlo_keywords = silent-discard, dsn

  # Disallow implicit subdomain matches in any table
  # Use leading dot as in .parent.domain for explicit matches
  parent_domain_matches_subdomains =

  smtpd_sender_restrictions =
    # Internal domains are only allowed to originate via the submission relay.
    check_sender_access texthash:$${inbound-postfix-internal-sender-access:output}

  smtpd_recipient_restrictions =
    permit_mynetworks
    # Reject synchronously when the backend will reject
    reject_unverified_recipient
    # Reject invalid SPF, permit valid SPF
    check_policy_service unix:private/policyd-spf
{% if greylisting_enable %}
    # Greylist missing SPF
    check_policy_service inet:127.0.0.1:$${postgrey-service:port}
{% endif %}

  policyd-spf_time_limit = 3600

  virtual_transport = relay
  relay_recipient_maps =
  relay_domains = {{ (mail_domains) | map(attribute='name') | join(',') }}
  transport_maps = texthash:$${internal-postfix-transport:output}

  # Server TLS parameters
  smtpd_tls_chain_files = $${inbound-postfix-certificate:bundle}
  smtpd_tls_security_level = may

  # Client TLS parameters
  smtp_tls_security_level = encrypt
  smtp_tls_chain_files = $${postfix-certificate:bundle}
  smtp_tls_session_cache_database = btree:$${inbound-postfix-directory:var-lib}/smtp_scache

  # Limits
  # Cap inbound message size at 100MiB (100 * 1024 * 1024)
  message_size_limit = 104857600

[inbound-postfix-internal-sender-access]
recipe = slapos.recipe.template:jinja2
output = $${inbound-postfix-directory:etc}/internal_sender_access
inline =
  {% raw %}{#- NOTHING -#}{% endraw -%}
  {%- for domain in mail_domains %}
  {{ domain['name'] }} REJECT Inbound relay refuses internal sender domains
  {%- endfor %}

[policyd-spf-conf]
recipe = slapos.recipe.template:jinja2
url = ${policyd_spf.jinja2.conf:target}
output = $${inbound-postfix-directory:etc}/policyd-spf.conf
context =

{% if greylisting_enable %}
[postgrey-service]
recipe = slapos.cookbook:wrapper
port = 10023
command-line =
  ${postgrey-perl:perl-bin} ${postgrey:location}/postgrey
    --inet=$${:port}
    --dbdir=$${postgrey-directory:data}
    --delay={{ greylisting_delay }}
    --max-age=30
    --user=$${userinfo:pw-name}
    --group=$${userinfo:gr-name}
    --whitelist-clients=$${postgrey-whitelist-clients:output}
    --whitelist-recipients=$${postgrey-whitelist-recipients:output}
wrapper-path = $${directory:service}/postgrey
depends =
  $${postgrey-whitelist-clients:recipe}
  $${postgrey-whitelist-recipients:recipe}

[postgrey-whitelist-clients]
recipe = slapos.recipe.template
output = $${inbound-postfix-directory:etc}/postgrey_whitelist_clients
inline =
  # Postgrey client whitelist
{% for entry in greylisting['whitelist-clients'] %}
  {{ entry }}{# single-line enforced by JSON schema #}
{% endfor %}

[postgrey-whitelist-recipients]
recipe = slapos.recipe.template
output = $${inbound-postfix-directory:etc}/postgrey_whitelist_recipients
inline =
  # Postgrey recipient whitelist
  # Add recipients that should never be greylisted, e.g.:
  # postmaster@
{% for entry in greylisting['whitelist-recipients'] %}
  {{ entry }}{# single-line enforced by JSON schema #}
{% endfor %}
{% endif %}

[inbound-postfix-wrapper]
<= macro.postfix-wrapper
etc = $${inbound-postfix-directory:etc}
spool-pid = $${inbound-postfix-directory:spool-pid}

[inbound-postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${inbound-postfix-wrapper:output}
wrapper-path = $${directory:service}/inbound-postfix
mode = 0775
pidfile = $${directory:run}/inbound_postfix.pid
environment =
  MAIL_CONFIG=$${inbound-postfix-directory:etc}
  SASL_CONF_PATH=$${inbound-postfix-directory:etc}
# Restart postfix on instance upgrade
hash-existing-files =
  ${buildout:directory}/buildout.cfg
depends =
  # Reload postfix on buildout run
  $${inbound-postfix-reload:recipe}
  # Pull dependent configuration and services
  $${inbound-postfix-main.cf:output}
  $${inbound-postfix-master.cf:output}
  $${policyd-spf-conf:recipe}
  {%- if greylisting_enable %}
  $${postgrey-service:recipe}
  {%- endif %}
  # Rotate logs periodically
  $${inbound-logrotate-entry-postfix:recipe}

[inbound-postfix-reload]
recipe = slapos.recipe.template
output = $${directory:script}/$${:_buildout_section_name_}
inline =
  #!/bin/sh -e
  export MAIL_CONFIG=$${inbound-postfix-directory:etc}
  ${postfix:location}/usr/sbin/postfix reload

[inbound-postfix-smtp-promise]
<= monitor-promise-base
promise = check_socket_listening
name = inbound_smtp_listen.py
config-host = {{ ipv6 }}
config-port = $${inbound-postfix-main.cf:smtp-port}

{% if custom_inbound_certificate -%}
[inbound-custom-certificate-expiration-promise]
<= monitor-promise-base
promise = check_command_execute
name = inbound_custom_certificate_not_expired.py
config-command =
  ${openssl:location}/bin/openssl x509 -checkend 432000 -noout \
    -in $${inbound-custom-certificate-bundle:output}
config-bang-on-failure = false

[inbound-custom-certificate-der]
recipe = slapos.recipe.build
to-der = ${certificate-to-der:output}
pem-path = $${inbound-custom-certificate-bundle:output}
location = $${inbound-postfix-directory:ssl}/custom.converted.der
install =
  import subprocess
  subprocess.call((options['to-der'], options['pem-path'], location))

[inbound-custom-certificate-served-promise]
recipe = slapos.cookbook:promise.plugin
eggs = slapos.core
file = ${check-smtpd-certificate:output}
output = $${directory:plugins}/inbound_custom_certificate_served.py
config-service-name = Inbound postfix
config-host = {{ ipv6 }}
config-port = $${inbound-postfix-main.cf:smtp-port}
config-certificate-der-path = $${inbound-custom-certificate-der:location}
{%- endif %}

[inbound-postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${inbound-postfix-certificate:recipe}
  $${inbound-postfix-service:recipe}
  $${postfix-wrappers:depends}
  $${inbound-postfix-smtp-promise:recipe}
{%- if custom_inbound_certificate %}
  $${inbound-custom-certificate-expiration-promise:recipe}
  $${inbound-custom-certificate-served-promise:recipe}
{%- endif %}
  $${inbound-postfix-shell-env:recipe}

[inbound-logrotate-entry-postfix]
<= logrotate-entry-base
name = inbound_postfix
log = $${inbound-postfix-main.cf:log-file}
copytruncate = true


# Postfix Backend Authentication
# ------------------------------

{% set source_host_list = [] -%}
{% for domain in mail_domains -%}
{%   if domain['authentication'] == 'none' -%}
{%     do source_host_list.append("[" + domain['mail-server-host'] + "]") -%}
{%   endif -%}
{% endfor -%}

{# Group IP-based sending domains by mail-server-host for per-host sender restrictions -#}
{% set sender_host_domains = {} -%}
{% for domain in mail_domains -%}
{%   if domain['authentication'] == 'none' -%}
{%     set host = domain['mail-server-host'] -%}
{%     if host not in sender_host_domains -%}
{%       do sender_host_domains.update({host: []}) -%}
{%     endif -%}
{%     do sender_host_domains[host].append(domain['name']) -%}
{%   endif -%}
{% endfor -%}
{% set sorted_sender_hosts = sender_host_domains.keys() | sort -%}

{# Collect password-authenticated sending domains -#}
{% set password_auth_domains = {} -%}
{% for domain in mail_domains -%}
{%   if domain['authentication'] == 'password' -%}
{%     do password_auth_domains.update({domain['name']: domain['password']}) -%}
{%   endif -%}
{% endfor -%}

{# Collect tls-fingerprint-authenticated sending domains -#}
{% set fingerprint_auth_backends = [] -%}
{% for backend in mail_domains -%}
{%   if backend['authentication'] == 'fingerprint' -%}
{%     do fingerprint_auth_backends.append(backend) -%}
{%   endif -%}
{% endfor -%}


{#- Configuration files for IP authentication #}
{#- ----------------------------------------- #}

{% for host in sorted_sender_hosts %}
[outbound-postfix-sender-access-{{ loop.index }}]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_access.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_access_{{ loop.index }}
context =
  import json_module json
  raw domains {{ json_module.dumps(sender_host_domains[host]) }}
{%- endfor %}

{% if sorted_sender_hosts -%}
[outbound-postfix-client-sender-access]
recipe = slapos.recipe.template:jinja2
url = ${postfix_client_sender_access.jinja2:target}
output = $${outbound-postfix-directory:etc}/client_sender_access
context =
  import json_module json
  raw sender_host_domains {{ json_module.dumps(sender_host_domains) }}
{%- endif %}


{#- Configuration files for password authentication #}
{#- ----------------------------------------------- #}

{% if password_auth_domains -%}
[outbound-postfix-smtpd-sasl-conf]
recipe = slapos.recipe.template:jinja2
url = ${postfix_smtpd_sasl.jinja2.conf:target}
config-path = $${outbound-postfix-directory:etc}
config-name = smtpd
output = $${:config-path}/$${:config-name}.conf
context =
  raw sasldb_path $${outbound-postfix-directory:etc}/sasldb2

[outbound-postfix-sender-login-map]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_login_map.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_login_map
password-auth-domains = {{ dumps(list(password_auth_domains.keys())) }}
context =
  key password_auth_domains :password-auth-domains
  key local_domain outbound-postfix-sasldb:local-domain

[outbound-postfix-sasldb]
recipe = plone.recipe.command
stop-on-error = true
sasldb-path = $${outbound-postfix-directory:etc}/sasldb2
# the SASL login name for a given sender will be <sender-domain>@relay
local-domain = relay
command =
  rm -f $${:sasldb-path}.tmp &&
  touch $${:sasldb-path}.tmp &&
{%- for domain, password in password_auth_domains.items() %}
  echo '{{ password }}' | ${cyrus-sasl:location}/sbin/saslpasswd2 \
    -f $${:sasldb-path}.tmp -p -c \
    -u $${:local-domain} {{ domain }} &&
{%- endfor %}
  mv -f $${:sasldb-path}.tmp $${:sasldb-path} &&
  echo "sasldb populated"
update-command = test -e $${:sasldb-path} || { $${:command}; }
{%- endif %}


{#- Configuration files for fingerprint authentication #}
{#- -------------------------------------------------- #}

{% if fingerprint_auth_backends -%}
[outbound-postfix-backend-clientcerts]
recipe = slapos.recipe.template:jinja2
output = $${outbound-postfix-directory:etc}/backend_clientcerts
prefix = restrict_fingerprint_sender_
inline =
  {% raw %}{#- NOTHING -#}{% endraw -%}
  {%- for index, backend in enumerate(fingerprint_auth_backends) -%}
  {%- for fingerprint in backend['fingerprints'] %}
  {{ fingerprint.strip() }} $${:prefix}{{ index }}
  {%- endfor %}
  {%- endfor %}

[outbound-postfix-backend-tls-policy-map]
recipe = slapos.recipe.template:jinja2
output = $${outbound-postfix-directory:etc}/backend_tls_policy_map
inline =
  {% raw %}{#- NOTHING -#}{% endraw -%}
  {%- for b in fingerprint_auth_backends %}
  [{{ b['mail-server-host'] }}]:{{ b['mail-server-port'] }} fingerprint
  {%- for fingerprint in b['fingerprints'] %}
    match={{ fingerprint.strip() }}
  {%- endfor %}
  {%- endfor %}
{%- endif %}


# Postfix Outbound SMTP server
# ----------------------------

[outbound-postfix-directory]
<= macro.postfix-directory
role = outbound

[outbound-postfix-shell-env]
<= macro.postfix-shell-env
etc = $${outbound-postfix-directory:etc}
role = outbound

[outbound-postfix-master.cf]
<= macro.postfix-master.cf
output = $${outbound-postfix-directory:etc}/master.cf
port = $${outbound-postfix-main.cf:submission-port}

[outbound-postfix-main.cf]
<= macro.postfix-main.cf
output = $${outbound-postfix-directory:etc}/main.cf
log-file = $${directory:var-log}/outbound_postfix.log
postfix-directory = outbound-postfix-directory
submission-port = 10587
content =
  mynetworks = [{{ ipv6 }}]/128 {{ ipv4 }} 127.0.0.0/8 {{ (source_host_list) | join(' ') }}

  virtual_transport = relay
  relay_recipient_maps =
  relay_domains = {{ (mail_domains) | map(attribute='name') | join(',') }}

  transport_maps = texthash:$${internal-postfix-transport:output}
  sender_dependent_default_transport_maps = texthash:$${outbound-postfix-sender-transport:output}

  # Server TLS parameters
  smtpd_tls_chain_files = $${postfix-certificate:bundle}
  # always require TLS
  smtpd_tls_security_level = encrypt
  # Ask for client certificate but do not require it
  smtpd_tls_ask_ccert = yes

  {% if password_auth_domains -%}
  # Server SASL
  smtpd_sasl_auth_enable = yes
  smtpd_sasl_path = $${outbound-postfix-smtpd-sasl-conf:config-name}
  cyrus_sasl_config_path = $${outbound-postfix-smtpd-sasl-conf:config-path}
  # the SASL login name will be <sender-domain>@<local-domain>
  smtpd_sasl_local_domain = $${outbound-postfix-sasldb:local-domain}
  smtpd_sasl_security_options = noanonymous

  # Server SASL Senders
  smtpd_sender_login_maps = texthash:$${outbound-postfix-sender-login-map:output}
  {%- endif %}

  # Sender authentication and auth/domain match enforcement
  smtpd_sender_restrictions =
  {%- if sorted_sender_hosts %}
    # Reject ip/domain mismatches for IP-authenticated senders
    check_client_access cidr:$${outbound-postfix-client-sender-access:output}
  {%- endif %}
  {%- if password_auth_domains %}
    # Reject login/domain mismatches for SASL-authenticated senders
    reject_sender_login_mismatch
  {%- endif %}
    # Permit IP-authenticated senders;
    # ip/domain mismatches are already rejected above
    permit_mynetworks
    # Permit SASL-authenticated senders;
    # password/domain mismatches are already rejected above
    permit_sasl_authenticated
  {%- if fingerprint_auth_backends %}
    # Permit TLS-fingerprint authenticated senders;
    # only matching fingerprint/domain pairs are accepted;
    # fingerprint/domain mismatches are rejected directly
    check_ccert_access texthash:$${outbound-postfix-backend-clientcerts:output}
  {%- endif %}
    # Reject all others
    reject

  smtpd_relay_restrictions =
    # Senders are previously authenticated by smtpd_sender_restrictions;
    # unauthenticated or unknown senders are already rejected there.
    # Permit senders that additionally have access to an external proxy
    # regardless of the recipient.
    check_sender_access texthash:$${outbound-postfix-proxy-senders:output}
    # Otherwise for senders that do not have access to an external proxy,
    # permit only recipients that are known backends.
    reject_unauth_destination

  {% if sorted_sender_hosts or fingerprint_auth_backends -%}
  smtpd_restriction_classes =
    # Per-host sender domain restrictions
    # Each sending backend is only allowed to use MAIL FROM with its own domains.
    {%- for host in sorted_sender_hosts %}
    restrict_sender_{{ loop.index }}
    {%- endfor %}
    {%- for index, backend in enumerate(fingerprint_auth_backends) %}
    $${outbound-postfix-backend-clientcerts:prefix}{{ index }}
    {%- endfor %}

  {% for host in sorted_sender_hosts -%}
  restrict_sender_{{ loop.index }} =
    check_sender_access texthash:$${outbound-postfix-sender-access-{{ loop.index }}:output}
    reject
  {% endfor %}

  {% for index, backend in enumerate(fingerprint_auth_backends) -%}
  $${outbound-postfix-backend-clientcerts:prefix}{{ index }} =
    check_sender_access inline:{{ '{{ %s = OK }}' % backend['name'] }}
    reject
  {% endfor %}
  {%- endif %}

  # Use system CAs to authenticate proxy; do not use permit_tls_all_clientcerts
  # Currently useless, because we only set may, not verify or better
  # We probably want to check backend certificates differently than proxy's,
  # assuming we keep allowing shortcut backend -> relay -> backend transport.
  tls_append_default_CA = yes

  # Client TLS parameters
  smtp_tls_security_level = may
  smtp_tls_session_cache_database = btree:$${outbound-postfix-directory:var-lib}/smtp_scache
  smtp_tls_chain_files = $${postfix-certificate:bundle}
  {%- if fingerprint_auth_backends %}
  smtp_tls_policy_maps = texthash:$${outbound-postfix-backend-tls-policy-map:output}
  {%- endif %}

  # Client SASL parameters
  smtp_sasl_auth_enable = yes
  smtp_sasl_security_options = noanonymous
  smtp_sasl_password_maps = texthash:$${outbound-postfix-proxy-passwd:output}
  smtp_sender_dependent_authentication = yes

  # Limits
  # Cap inbound message size at 100MiB (100 * 1024 * 1024)
  message_size_limit = 104857600

[outbound-postfix-sender-transport]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sender_dependent_transport.jinja2:target}
output = $${outbound-postfix-directory:etc}/sender_dependent_transport
context =
  import json_module json
  raw proxy_map {{ json_module.dumps(proxy_map) }}

[outbound-postfix-proxy-senders]
recipe = slapos.recipe.template:jinja2
output = $${outbound-postfix-directory:etc}/proxy_access_senders
inline =
  {% raw %}{#- NOTHING -#}{% endraw -%}
  {%- for proxy_id, proxy in proxy_map.items() -%}
  {%- for domain in proxy.get('domains', []) %}
  {{ domain }} OK
  {%- endfor %}
  {%- endfor %}

[outbound-postfix-proxy-passwd]
recipe = slapos.recipe.template:jinja2
url = ${postfix_proxy_sasl_passwd_map.jinja2:target}
output = $${outbound-postfix-directory:etc}/proxy_sasl_passwd
context =
  import json_module json
  raw proxy_map {{ json_module.dumps(proxy_map) }}

[outbound-postfix-wrapper]
<= macro.postfix-wrapper
etc = $${outbound-postfix-directory:etc}
spool-pid = $${outbound-postfix-directory:spool-pid}

[outbound-postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${outbound-postfix-wrapper:output}
wrapper-path = $${directory:service}/outbound-postfix
mode = 0775
pidfile = $${directory:run}/outbound_postfix.pid
environment =
  MAIL_CONFIG=$${outbound-postfix-directory:etc}
  SASL_CONF_PATH=$${outbound-postfix-directory:etc}
# Restart postfix on instance upgrade
hash-existing-files =
  ${buildout:directory}/buildout.cfg
depends =
  # Reload postfix on buildout run
  $${outbound-postfix-reload:recipe}
  # Pull dependent configuration and services
  $${outbound-postfix-main.cf:output}
  $${outbound-postfix-master.cf:output}
  # Rotate logs periodically
  $${outbound-logrotate-entry-postfix:recipe}

[outbound-postfix-reload]
recipe = slapos.recipe.template
output = $${directory:script}/$${:_buildout_section_name_}
inline =
  #!/bin/sh -e
  export MAIL_CONFIG=$${outbound-postfix-directory:etc}
  ${postfix:location}/usr/sbin/postfix reload

[outbound-postfix-certificate-served-promise]
recipe = slapos.cookbook:promise.plugin
eggs = slapos.core
file = ${check-smtpd-certificate:output}
output = $${directory:plugins}/outbound_certificate_served.py
config-service-name = Outbound postfix
config-host = {{ ipv6 }}
config-port = $${outbound-postfix-main.cf:submission-port}
config-certificate-der-path = $${postfix-certificate:der}

[outbound-postfix-submission-promise]
<= monitor-promise-base
promise = check_socket_listening
name = outbound_subm_listen.py
config-host = {{ ipv6 }}
config-port = $${outbound-postfix-main.cf:submission-port}

[outbound-postfix]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${outbound-postfix-service:recipe}
  $${postfix-wrappers:depends}
  $${outbound-postfix-certificate-served-promise:recipe}
  $${outbound-postfix-submission-promise:recipe}
  $${outbound-postfix-shell-env:recipe}

[outbound-logrotate-entry-postfix]
<= logrotate-entry-base
name = outbound_postfix
log = $${outbound-postfix-main.cf:log-file}
copytruncate = true


# Postfix Wrappers
# ----------------

[base-wrapper]
recipe = slapos.cookbook:wrapper

[base-bin-wrapper]
<= base-wrapper
command-line = $${:path}/$${:basename}
wrapper-path = $${directory:bin}/$${:basename}

[base-bin-bin-wrapper]
<= base-bin-wrapper
path = ${postfix:location}/usr/bin

[base-sbin-bin-wrapper]
<= base-bin-wrapper
path = ${postfix:location}/usr/sbin

{% set postfix_wrappers = [] -%}
{% for extend, basename_list in (
  (
    'base-bin-bin-wrapper',
    (
      'mailq',
      'newaliases',
    ),
  ),
  (
    'base-sbin-bin-wrapper',
    (
      'postcat',
      'postconf',
      'postdrop',
      'postfix',
      'postkick',
      'postlock',
      'postlog',
      'postmap',
      'postmulti',
      'postqueue',
      'postsuper',
      'sendmail',
    ),
  ),
) %}
{%   for basename in basename_list -%}
{%     do postfix_wrappers.append('wrapper-' ~ basename) -%}
[wrapper-{{ basename }}]
<= {{ extend }}
basename = {{ basename }}
{%   endfor %}
{% endfor %}

[qshape]
<= base-wrapper
wrapper-path = $${directory:bin}/$${:_buildout_section_name_}
command-line =
  ${perl:location}/bin/perl
    ${postfix:location}/auxiliary/qshape/qshape.pl

[postfix-wrappers]
depends =
  $${qshape:recipe}
{%- for postfix_wrapper in postfix_wrappers %}
  {{ "$${" + postfix_wrapper + ":recipe}" }}
{%- endfor %}
