{
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Input Parameters",
  "properties": {
    "cell1": {
      "title": "Cell Parameters",
      "description": "Radio parameters related to the cell",
      "$ref": "#/$defs/ors_cell"
    },
    "management": {
      "title": "ORS Management Parameters",
      "description": "Parameters which are not related to radio, such as promise thresholds, statistical collection, log verbosity etc...",
      "properties": {
        "xlog_enabled": {
          "$ref": "instance-enb-input-schema.json#/properties/xlog_enabled"
        },
        "xlog_forwarding_enabled": {
          "$ref": "instance-enb-input-schema.json#/properties/xlog_forwarding_enabled"
        },
        "websocket_url_ipv6": {
          "$ref": "instance-enb-input-schema.json#/properties/websocket_url_ipv6"
        }
      },
      "type": "object",
      "default": {}
    },
    "monitor-interface-url": {
      "$ref": "instance-ors-gnb-input-schema.json#/properties/monitor-interface-url"
    }
  },
  "$defs": {
    "ors_cell": {
      "oneOf": [
        {
          "title": "gNB Cell",
          "required": [
            "enable_cell"
          ],
          "allOf": [
            {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "title": "Cell Type",
              "type": "object",
              "properties": {
                "enable_cell": {
                  "title": "Enable Cell: You must select this parameter to enable the cell",
                  "type": "string",
                  "enum": [
                    "Enable gNB",
                    "Disable gNB"
                  ],
                  "default": "Enable gNB"
                }
              }
            },
            {
              "$ref": "ors-cell.json"
            },
            {
              "$ref": "ors-gnb-cell.json"
            }
          ],
          "type": "object"
        }
      ],
      "type": "object",
      "default": {}
    }
  }
}
