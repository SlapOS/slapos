{
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Input Parameters",
  "properties": {
    "rf-info": {
      "$ref": "instance-ors-enb-gnb-input-schema.json#/properties/rf-info"
    }
  },
  "$defs": {
    "enable_cell_gnb": {
      "title": "Enable Cell: You must select this parameter to enable the cell",
      "type": "string",
      "enum": [
        "Enable gNB",
        "Disable gNB"
      ],
      "default": "Enable gNB"
    },
    "enable_cell_enb": {
      "$ref": "#/$defs/enable_cell_gnb",
      "default": "Enable eNB"
    },
    "ors_cell": {
      "oneOf": [
        {
          "title": "gNB Cell",
          "required": [
            "enable_cell"
          ],
          "allOf": [
            {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "title": "Cell Type",
              "type": "object",
              "properties": {
                "enable_cell": {
                  "$ref": "#/$defs/enable_cell_gnb"
                }
              }
            },
            {
              "$ref": "ors-cell.json"
            },
            {
              "$ref": "ors-gnb-cell.json"
            },
            {
              "$ref": "ors-cell-secondary.json"
            }
          ],
          "type": "object"
        },
        {
          "title": "eNB Cell",
          "required": [
            "enable_cell"
          ],
          "allOf": [
            {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "title": "Cell Type",
              "type": "object",
              "properties": {
                "enable_cell": {
                  "$ref": "#/$defs/enable_cell_enb"
                }
              }
            },
            {
              "$ref": "ors-cell.json"
            },
            {
              "$ref": "ors-enb-cell.json"
            },
            {
              "$ref": "ors-cell-secondary.json"
            }
          ],
          "type": "object"
        }
      ],
      "type": "object",
      "default": {}
    }
  }
}
