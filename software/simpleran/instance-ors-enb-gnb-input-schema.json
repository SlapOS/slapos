{
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Input Parameters",
  "properties": {
    "cell1": {
      "title": "Cell Parameters",
      "description": "Radio parameters related to the cell",
      "$ref": "#/$defs/ors_cell"
    },
    "nodeb": {
      "title": "eNB Parameters",
      "description": "Parameters not related to a single cell but to the eNB",
      "allOf": [
        {
          "$ref": "ors-enb-gnb-classic.json"
        },
        {
          "$ref": "ors-enb-gnb.json"
        }
      ],
      "type": "object",
      "default": {}
    },
    "management": {
      "title": "ORS Management Parameters",
      "description": "Parameters which are not related to radio, such as promise thresholds, statistical collection, log verbosity etc...",
      "allOf": [
        {
          "$ref": "ors-params.json"
        }
      ],
      "type": "object",
      "default": {}
    },
    "monitor-interface-url": {
      "title": "Monitor Interface URL",
      "description": "URL to the monitor app used in monitor setup URL",
      "type": "string",
      "default": "https://monitor.app.officejs.com/#page=ojsm_landing"
    },
    "rf-info": {
      "title": "Expert only: RF Info",
      "description": "Expert only: override RF Info from parameters",
      "type": "string",
      "textarea": true
    }
  },
  "$defs": {
    "enable_cell_gnb": {
      "title": "Enable Cell: You must select this parameter to enable the cell",
      "type": "string",
      "enum": [
        "Enable gNB",
        "Disable gNB"
      ],
      "default": "Enable gNB"
    },
    "enable_cell_enb": {
      "title": "Enable Cell: You must select this parameter to enable the cell",
      "enum": [
        "Enable eNB",
        "Disable eNB"
      ],
      "default": "Enable eNB"
    },
    "enable_cell_nb": {
      "title": "Enable Cell: You must select this parameter to enable the cell",
      "enum": [
        "Enable NB IOT",
        "Disable NB IOT"
      ],
      "default": "Enable NB IOT"
    },
    "ors_cell": {
      "oneOf": [
        {
          "title": "gNB Cell",
          "required": [
            "enable_cell"
          ],
          "allOf": [
            {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "title": "Cell Type",
              "type": "object",
              "properties": {
                "enable_cell": {
                  "$ref": "#/$defs/enable_cell_gnb"
                }
              }
            },
            {
              "$ref": "ors-cell.json"
            },
            {
              "$ref": "ors-gnb-cell.json"
            },
            {
              "$ref": "ors-cell-secondary.json"
            }
          ],
          "type": "object"
        },
        {
          "title": "eNB Cell",
          "required": [
            "enable_cell"
          ],
          "allOf": [
            {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "title": "Cell Type",
              "type": "object",
              "properties": {
                "enable_cell": {
                  "$ref": "#/$defs/enable_cell_enb"
                }
              }
            },
            {
              "$ref": "ors-cell.json"
            },
            {
              "$ref": "ors-enb-cell.json"
            },
            {
              "$ref": "ors-cell-secondary.json"
            }
          ],
          "type": "object"
        },
        {
          "title": "NB IOT Cell",
          "required": [
            "enable_cell"
          ],
          "allOf": [
            {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "title": "Cell Type",
              "type": "object",
              "properties": {
                "enable_cell": {
                  "$ref": "#/$defs/enable_cell_nb"
                }
              }
            },
            {
              "$ref": "ors-cell.json"
            },
            {
              "$ref": "ors-nb-cell.json"
            },
            {
              "$ref": "ors-cell-secondary.json"
            }
          ],
          "type": "object"
        }
      ],
      "type": "object",
      "default": {}
    }
  }
}
