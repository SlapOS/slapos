{
  "type": "object",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Input Parameters",
  "properties": {
    "ors_duo_2nd_cell": {
      "title": "Second Cell",
      "description": "Radio parameters of the second cell of ORS Duo used in Carrier Aggregation mode (please see ORS Duo Mode parameter)",
      "oneOf": [
        {
          "$ref": "ors-duo-enb.json"
        }
      ],
      "type": "object",
      "default": {}
    },
    "n_antenna_dl": {
      "$ref": "ors-common.json#/properties/n_antenna_dl",
      "enum": [
        1,
        2,
        4
      ],
      "default": 4
    },
    "n_antenna_ul": {
      "$ref": "ors-common.json#/properties/n_antenna_dl",
      "enum": [
        1,
        2,
	4
      ],
      "default": 4
    },
    "ors_duo_mode": {
      "title": "ORS Duo Mode",
      "description": "Carrier aggregation: aggregate two cells to do up to 100 MHz of bandwidth.",
      "type": "string",
      "enum": [
        "Carrier Aggregation",
        "Single Cell"
      ],
      "default": "Single Cell"
    }
  }
}
