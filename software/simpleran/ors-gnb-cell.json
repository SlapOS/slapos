{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ORS NR Cell",
  "type": "object",
  "properties": {
    "nr_bandwidth": {
      "title": "Bandwidth",
      "description": "Downlink Bandwidth",
      "enum": [
        "3 MHz",
        "5 MHz",
        "7 MHz",
        "10 MHz",
        "15 MHz",
        "20 MHz",
        "25 MHz",
        "30 MHz",
        "35 MHz",
        "40 MHz",
        "45 MHz",
        "50 MHz"
      ],
      "type": "string"
    },
    "dl_frequency": {
      "title": "DL Frequency",
      "description": "Downlink center frequency of the cell. Default depends on your ORS model, please refer to the connection parameters. Make sure to not set a value outside the range of your ORS",
      "type": "number"
    },
    "tdd_ul_dl_config": {
      "$ref": "cell/nr/input-schema.json#/properties/tdd_ul_dl_config"
    }
  }
}
