{%- set fixed_ip = slapparameter_dict.fixed_ips %}

{% set part_list = [] -%}
{%- for s in sim_list %}
{%    set publish_section_title = 'publish-%s' % s.slave_reference %}
{%    do part_list.append(publish_section_title) %}
[{{ publish_section_title }}]
recipe = slapos.cookbook:publish.serialised
-slave-reference = {{ s.slave_reference }}
{%- if 'error' in s %}
error = {{ s.error }}
{%- elif s.get('disable_sim', '') == 'Disable SIM' %}
info = Your SIM was disabled, you can enable it back by updating it's parameter.
{%- else %}
info = Your SIM card has been attached to service  {{ slap_configuration['instance-title'] }}.
plmn         = {{ s.get('plmn', 'No PLMN defined'        ) }}
msin         = {{ s.get('msin', 'No MSIN defined'        ) }}
imsi         = {{ s.get('imsi', 'No IMSI defined'        ) }}
impi         = {{ s.get('impi', 'No IMPI defined'        ) }}
impu         = {{ s.get('impu', 'No IMPU defined'        ) }}
secret-key   = {{ s.get('k'   , 'No Secret Key defined'  ) }}
operator-key = {{ s.get('opc' , 'No Operator Key defined') }}
{%-     if fixed_ip %}
ipv4 = {{ s.ip }}
{%-     endif %}
{%- endif %}
{%- endfor %}

{%- for s in dns_list %}
{%    set publish_section_title = 'publish-%s' % s.slave_reference %}
{%    do part_list.append(publish_section_title) %}
[{{ publish_section_title }}]
recipe = slapos.cookbook:publish.serialised
-slave-reference = {{ s.slave_reference }}
domain = {{ s.subdomain }}.{{ s.get('domain', slapparameter_dict.get('local_domain', '')) }}
ip = {{ s.get('ip', '') }}
info = DNS entry has been attached to service {{ slap_configuration['instance-title'] }}.
{%- endfor %}

[buildout]
parts =
  directory
  mme-config
  mme-service
  ims-config
  mt-call-config
  publish-mme-config
  publish-ims-config
  publish-mt-call-config
  publish-ue-db-config
  ims-service
  monitor-base
  check-interface-up.py
  publish-connection-information
  ws-mme-websocket-promise
  ws-mme-nginx-launcher
  ws-mme-nginx-graceful
  ws-ims-websocket-promise
  ws-ims-nginx-launcher
  ws-ims-nginx-graceful
# Don't add these sections during unit tests as there is no TUN IPv4 available
{% if not slapparameter_dict.testing %}
  ims-mms-listen-promise
{%-  for i in range(slapparameter_dict.iperf3) %}
  iperf-service-{{ i }}
  iperf-{{ i }}-listen-promise
{%-  endfor %}
{%   if slapparameter_dict.get("local_domain", '') %}
  dnsmasq-service
{%   endif %}
{% endif %}
{% for part in part_list -%}
{{ '  %s' % part }}
{% endfor %}

extends = {{ monitor_template }}

eggs-directory = {{ eggs_directory }}
develop-eggs-directory = {{ develop_eggs_directory }}
offline = true

[myslap]
# NOTE we don't query slapos.cookbook:slapconfiguration the second time because
# slapparameter_dict is potentially modified with defaults.
slapparameter_dict = {{ dumps(slapparameter_dict) }}
slap_configuration = {{ dumps(slap_configuration) }}
sim_list = {{ dumps(sim_list) }}

[monitor-httpd-conf-parameter]
httpd-include-file = {{ buildout_directory }}/etc/httpd-include-file.conf
port = ${monitor-instance-parameter:monitor-httpd-port}
url = https://[${monitor-instance-parameter:monitor-httpd-ipv6}]:${:port}

[monitor-instance-parameter]
monitor-httpd-port = ${monitor-address:port}

[monitor-address]
recipe = slapos.cookbook:free_port
minimum = 8035
maximum = 8055
ip = ${monitor-instance-parameter:monitor-httpd-ipv6}

[directory]
recipe = slapos.cookbook:mkdirectory
software = {{ buildout_directory }}
home = ${buildout:directory}
etc = ${:home}/etc
var = ${:home}/var
bin = ${:home}/bin
tmp = ${:home}/tmp
run = ${:var}/run
script = ${:etc}/run
service = ${:etc}/service
promise = ${:etc}/promise
log = ${:var}/log

[ims-sh-wrapper]
recipe = slapos.recipe.template
output = ${directory:bin}/${:_buildout_section_name_}
ims-log = ${directory:log}/ims.log
info-log = ${directory:log}/ims-info.log
start-date = ${directory:run}/ims-start.date
max-combined-ims-log-kb-size   = 1000000
max-combined-info-log-kb-size  = 500000
max-info-log-kb-size           = 100000
inline =
  #!/bin/sh
  # Amarisoft init scripts
  sudo -n {{ amarisoft['dir'] }}/init-mme;
  rm -f ${directory:var}/lte_ue.db;
  # Print hardware and software info in info-log
  cat >> ${:info-log} << EOF



  $(date "+[%Y/%m/%d %T.%N %Z] Starting IMS...")
  System info: $(uname -a)

  EOF
  # Remove obsolete logs
  rm -f ${directory:log}/ims-output*
  /bin/sh {{ amarisoft_log_rotate_sh }} \
            ${:start-date} \
            ${:ims-log} \
            ${:info-log} \
            ${:max-combined-ims-log-kb-size} \
            ${:max-combined-info-log-kb-size} \
            ${:max-info-log-kb-size}
  {{ amarisoft['ims_dir'] }}/lteims ${directory:etc}/ims.cfg >> ${:info-log} 2>> ${:info-log};

### IMS
[ims-service]
recipe = slapos.cookbook:wrapper
command-line = ${ims-sh-wrapper:output}
wrapper-path = ${directory:service}/ims
mode = 0775
pidfile = ${directory:run}/ims.pid
hash-files =
  ${ims-config:output}
  ${mt-call-config:output}
  ${ue-db-config:output}
  ${ims-sh-wrapper:output}
environment =
  AMARISOFT_PATH={{ amarisoft['license_dir'] }}

[mme-sh-wrapper]
recipe = slapos.recipe.template
output = ${directory:bin}/${:_buildout_section_name_}
mme-log = ${directory:log}/mme.log
info-log = ${directory:log}/mme-info.log
start-date = ${directory:run}/mme-start.date
max-combined-mme-log-kb-size   = 1000000
max-combined-info-log-kb-size  = 500000
max-info-log-kb-size           = 100000
inline =
  #!/bin/sh
  # Amarisoft init scripts
  sudo -n {{ amarisoft['dir'] }}/init-mme;
  rm -f ${directory:var}/lte_ue.db;
  # Print hardware and software info in info-log
  cat >> ${:info-log} << EOF



  $(date "+[%Y/%m/%d %T.%N %Z] Starting MME...")
  System info: $(uname -a)
  
  EOF
  # Remove obsolete logs
  rm -f ${directory:log}/mme-output*
  /bin/sh {{ amarisoft_log_rotate_sh }} \
            ${:start-date} \
            ${:mme-log} \
            ${:info-log} \
            ${:max-combined-mme-log-kb-size} \
            ${:max-combined-info-log-kb-size} \
            ${:max-info-log-kb-size}
  {{ amarisoft['mme_dir'] }}/ltemme ${directory:etc}/mme.cfg >> ${:info-log} 2>> ${:info-log};

### MME
[mme-service]
recipe = slapos.cookbook:wrapper
command-line = ${mme-sh-wrapper:output}
wrapper-path = ${directory:service}/mme
mode = 0775
pidfile = ${directory:run}/mme.pid
hash-files =
  ${mme-config:output}
  ${ue-db-config:output}
  ${mme-sh-wrapper:output}
environment =
  AMARISOFT_PATH={{ amarisoft['license_dir'] }}

### EMPTY mme-ifup script
[mme-ifup-empty]
recipe = slapos.cookbook:wrapper
wrapper-path = ${directory:bin}/mme-ifup-empty
command-line = echo Using interface
mode = 775

{%- for i in range(slapparameter_dict.iperf3) %}
[iperf-service-{{ i }}]
recipe = slapos.cookbook:wrapper
port = {{ 5001 + i }}
ip = {{ slap_configuration['tun-ipv4-addr'] }}
command-line = {{ iperf3_location }}/bin/iperf3 --server --interval 1 --port ${:port} --bind ${:ip}
wrapper-path = ${directory:service}/iperf3-{{ i }}
mode = 0775
pidfile = ${directory:run}/iperf3-{{ i }}.pid

[iperf-{{ i }}-listen-promise]
<= monitor-promise-base
promise = check_socket_listening
name = iperf-{{ i }}-port-listening.py
config-host = ${iperf-service-{{ i }}:ip}
config-port = ${iperf-service-{{ i }}:port}
{% endfor %}

[publish-config-base]
recipe = slapos.cookbook:symbolic.link
target-directory = ${monitor-directory:private}

[config-base]
recipe = slapos.recipe.template:jinja2
extensions = jinja2.ext.do
extra-context =
context =
  section directory directory
  key slap_configuration myslap:slap_configuration
  key slapparameter_dict myslap:slapparameter_dict
  import json_module json
  import  netaddr netaddr
  key ifup_empty mme-ifup-empty:wrapper-path
  ${:extra-context}
  key ue_db_config ue-db-config:output

[ims-config]
<= config-base
url = {{ ims_template }}
output = ${directory:etc}/ims.cfg
extra-context =
    key websocket_password ws-ims-websocket-password:passwd

[publish-ims-config]
<= publish-config-base
link-binary = ${ims-config:output}

[mt-call-config]
<= config-base
url = {{ mt_call_template }}
output = ${directory:etc}/mt_call_qos.sdp

[publish-mt-call-config]
<= publish-config-base
link-binary = ${mt-call-config:output}

[ue-db-config]
<= config-base
url = {{ ue_db_template }}
output = ${directory:etc}/ue_db.cfg
extra-context =
  key sim_list myslap:sim_list

[publish-ue-db-config]
<= publish-config-base
link-binary = ${ue-db-config:output}

[mme-config]
<= config-base
url = {{ mme_template }}
output = ${directory:etc}/mme.cfg
extra-context =
    key websocket_password ws-mme-websocket-password:passwd

[publish-mme-config]
<= publish-config-base
link-binary = ${mme-config:output}

[ims-mms-listen-promise]
<= monitor-promise-base
promise = check_socket_listening
name = ims-mms-port-listening.py
config-host = {{ slapparameter_dict.internet_ipv4 }}
config-port = 1111

{% if slapparameter_dict.get("local_domain", '') %}
[dnsmasq-config]
recipe = slapos.recipe.template:jinja2
url = {{dnsmasq_template}}
filename = dnsmasq.cfg
extensions = jinja2.ext.do
output = ${directory:etc}/${:filename}
context =
  import json_module json
  import netaddr netaddr
  section directory directory
  key slap_configuration myslap:slap_configuration
  key slapparameter_dict myslap:slapparameter_dict

[dnsmasq-service]
recipe = slapos.cookbook:wrapper
port = 5353
ip = {{ slap_configuration['tun-ipv4-addr'] }}
command-line = {{ dnsmasq_location }}/sbin/dnsmasq --conf-file=${dnsmasq-config:output} -x ${directory:run}/dnsmasq.pid --local-service --keep-in-foreground
wrapper-path = ${directory:service}/dnsmasq
mode = 0775
hash-files =
  ${dnsmasq-config:output}

#[dnsmasq-listen-promise]
#<= monitor-promise-base
#promise = check_socket_listening
#name = dnsmasq-port-listening.py
#config-host = ${dnsmasq-service:ip}
#config-port = ${dnsmasq-service:port}
{% endif %}

[monitor-instance-parameter]
{% if slapparameter_dict.get("name", None) %}
monitor-title = {{ slapparameter_dict['name'] | string }}
{% endif %}
{% if slapparameter_dict.get("monitor-password", None) %}
password = {{ slapparameter_dict['monitor-password'] | string }}
{% endif %}

{% set imsi_list = [] -%}
{%- for s in sim_list %}
{%-   if s.get('disable_sim', '') != 'Disable SIM' %}
{%-     do imsi_list.append(s.imsi) %}
{%-   endif %}
{%- endfor %}

{%- macro websocket_frontend(name, nginx_port, addr, port)  %}


[ws-{{ name }}-websocket-password]
recipe = slapos.cookbook:generate.password
storage-path = ${directory:etc}/.{{ name }}_websocket_pwd

[ws-{{ name }}-request-slave-frontend]
recipe = slapos.cookbook:requestoptional
server-url = ${slap-connection:server-url}
key-file = ${slap-connection:key-file}
cert-file = ${slap-connection:cert-file}
computer-id = ${slap-connection:computer-id}
partition-id = ${slap-connection:partition-id}
state = {{ slap_configuration['instance-state'] }}
shared = true
config-https-only = True
config-type = websocket
config-websocket-path-list = ${ws-{{ name }}-nginx-params:websocket-path}
config-url = https://[${ws-{{ name }}-nginx-params:ip}]:${ws-{{ name }}-nginx-params:port}
return = secure_access domain
software-url = http://git.erp5.org/gitweb/slapos.git/blob_plain/HEAD:/software/apache-frontend/software.cfg
software-type = default
name = {{ name }} Websocket Frontend

[ws-{{ name }}-nginx-tempdir]
recipe = slapos.cookbook:mkdirectory
tmp = ${buildout:directory}/tmp
tmp-{{ name }} = ${:tmp}/{{ name }}
client-body-temp-path = ${:tmp-{{ name }}}/client_body_temp_path
proxy-temp-path = ${:tmp-{{ name }}}/proxy_temp_path
fastcgi-temp-path = ${:tmp-{{ name }}}/fastcgi_temp_path
uwsgi-temp-path = ${:tmp-{{ name }}}/uwsgi_temp_path
scgi-temp-path = ${:tmp-{{ name }}}/scgi_temp_path

[ws-{{ name }}-nginx-launcher]
recipe = slapos.cookbook:wrapper
command-line = {{ nginx_executable }} -c ${ws-{{ name }}-nginx-config:output}
wrapper-path = ${directory:services}/{{ name }}-nginx
hash-files = ${ws-{{ name }}-nginx-config:output}
hash-existing-files = ${buildout:directory}/software_release/buildout.cfg
wait-for-files =
  ${ws-{{ name }}-ca-websocket:key-file}
  ${ws-{{ name }}-ca-websocket:cert-file}

[ws-{{ name }}-nginx-config]
recipe = slapos.recipe.template:jinja2
url = {{ nginx_template }}
output = ${directory:etc}/{{ name }}-nginx.conf
context =
    section params ws-{{ name }}-nginx-params
    section ca ws-{{ name }}-ca-websocket
    section tempdir ws-{{ name }}-nginx-tempdir
    raw mime {{ nginx_mime }}

[ws-{{ name }}-nginx-params]
path-pid = ${directory:run}/{{ name }}-nginx.pid
path-error-log = ${directory:log}/{{ name }}-nginx-error.log
path-access-log = ${directory:log}/{{ name }}-nginx-access.log
ip = {{ my_ipv6 }}
port = {{ nginx_port }}
websocket-ip = {{ addr }}
websocket-port = {{ port }}
websocket-path = websocket
nb-workers = 2

[ws-{{ name }}-nginx-graceful]
recipe = slapos.recipe.template
output = ${directory:scripts}/{{ name }}-nginx-graceful
inline =
  #!/bin/sh
  exec kill -s SIGHUP $(cat ${ws-{{ name }}-nginx-params:path-pid})

[ws-{{ name }}-ca-websocket]
<= certificate-authority
recipe = slapos.cookbook:certificate_authority.request
key-file = ${directory:etc}/{{ name }}-websocket.key
cert-file = ${directory:etc}/{{ name }}-websocket.crt
executable = true
wrapper = ${directory:bin}/UNUSED-{{ name }}-nginx-with-ca

[ws-{{ name }}-frontend-urlparse]
recipe = slapos.recipe.build
domain = ${ws-{{ name }}-request-slave-frontend:connection-domain}
init =
  import six.moves.urllib.parse as urlparse
  parsed_url = urlparse.urlparse('wss://' + options['domain'])
  if parsed_url.hostname:
    options['hostname'] = parsed_url.hostname + '/websocket'
  else:
    options['hostname'] = None
  options['raw_hostname'] = parsed_url.hostname
  options['port'] = parsed_url.port if parsed_url.port else 443

[ws-{{ name }}-websocket-promise]
<= monitor-promise-base
promise = check_socket_listening
name = {{ name }}_websocket_promise.py
config-host = ${ws-{{ name }}-frontend-urlparse:raw_hostname}
config-port = ${ws-{{ name }}-frontend-urlparse:port}
{%- endmacro    %}

{{ websocket_frontend("mme", 6081, slapparameter_dict.mme_com_addr, slapparameter_dict.mme_com_ws_port) }}
{{ websocket_frontend("ims", 6082, slapparameter_dict.ims_com_addr, slapparameter_dict.ims_com_ws_port) }}

[monitor-publish-connection-information]
<= monitor-publish

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
{%- for p in publish %}
{{ p }} = {{ publish[p] }}
{%- endfor %}
{%- if slapparameter_dict.websocket_url_ipv6 %}
URL.websocket-mme-hostname = {{ slapparameter_dict.mme_com_addr }}
URL.websocket-mme-port = {{ slapparameter_dict.mme_com_ws_port }}
URL.websocket-ims-hostname = {{ slapparameter_dict.ims_com_addr }}
URL.websocket-ims-port = {{ slapparameter_dict.ims_com_ws_port }}
{%- else %}
URL.websocket-mme-hostname = ${ws-mme-frontend-urlparse:hostname}
URL.websocket-mme-port = ${ws-mme-frontend-urlparse:port}
URL.websocket-mme-password = ${ws-mme-websocket-password:passwd}
URL.websocket-ims-hostname = ${ws-ims-frontend-urlparse:hostname}
URL.websocket-ims-port = ${ws-ims-frontend-urlparse:port}
URL.websocket-ims-password = ${ws-ims-websocket-password:passwd}
{%- endif %}
{%- if not slapparameter_dict.websocket_url_ipv6 %}
URL.websocket-amarisoft-gui = https://tech-academy.amarisoft.com/web-gui/
{%- endif %}
NETWORK.core-network-ipv6 = {{ my_ipv6 }}
AMARISOFT.version = {{ amarisoft['version_cn'] }}
AMARISOFT.host-id = {{ amarisoft['ltemme_host_id'] }}
AMARISOFT.installed-version = {{ amarisoft['version_installed'] }}
AMARISOFT.license-expiration = {{ amarisoft['ltemme_expiration'] }}
CORE.plmn = {{ slapparameter_dict.core_network_plmn }}
{%- if not slapparameter_dict.testing  %}
{%-   if slapparameter_dict.iperf3 %}
IPERF3.server-ipv4 = ${iperf-service-0:ip}
{%-   endif %}
{%-   for i in range(1, slapparameter_dict.iperf3 + 1) %}
IPERF3.server-{{ i - 1 }}-port = ${iperf-service-{{ i - 1 }}:port}
{%-   endfor %}
{%  endif%}
URL.monitor-base = ${monitor-publish-connection-information:monitor-base-url}
URL.monitor-setup = ${monitor-publish-connection-information:monitor-setup-url}
URL.monitor-gadget = ${:URL.monitor-base}/gadget/software.cfg.html
SIM.sim-list = {{ imsi_list | join(', ') }}

[macro.promise]
<= monitor-promise-base
name = ${:_buildout_section_name_}

[check-disk-space.py]
<= macro.promise
eggs = slapos.toolbox[prediction]
promise = check_free_disk_space
config-collectordb = ${monitor-instance-parameter:collector-db}
config-frequency = 5
config-threshold = 0.08
config-nb-days-predicted = 10
config-display-partition = 1
config-display-prediction = 1

[check-interface-up.py]
<= macro.promise
promise = check_interface_up
config-testing = {{ slapparameter_dict.testing }}
{% if not slapparameter_dict.testing %}
config-ifname = {{ slap_configuration['tun-name'] }}
{% else %}
config-ifname =
{% endif %}
