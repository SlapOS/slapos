{
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ORS eNB / gNB",
  "properties": {
    "gnb_id": {
      "$ref": "instance-enb-input-schema.json#/properties/gnb_id",
      "description": "eNB ID. Equal to (ORS serial number + 524288) modulo 1048576 by default"
    },
    "gnb_id_bits": {
      "$ref": "instance-enb-input-schema.json#/properties/gnb_id_bits",
      "default": 28
    },
    "amf_list": {
      "$ref": "instance-enb-input-schema.json#/properties/amf_list",
      "description": "List of AMF to which the gNodeB is connected. (default: Local Core Network, 127.0.1.100)",
      "default": [
        {
          "name": "Local Core Network",
          "amf_addr": "127.0.1.100"
        }
      ]
    },
    "plmn_list_5g": {
      "$ref": "instance-enb-input-schema.json#/properties/plmn_list_5g",
      "description": "List of PLMNs broadcasted by the gNodeB, at most 12 (default: PLMN 00101 and TAC 1)",
      "default": [
        {
          "plmn": "00101",
          "tac": "0x01"
        }
      ]
    },
    "enb_id": {
      "$ref": "instance-enb-input-schema.json#/properties/enb_id",
      "description": "eNB ID. Equal to ORS serial number modulo 1048576 by default"
    },
    "mme_list": {
      "$ref": "instance-enb-input-schema.json#/properties/mme_list",
      "description": "List of MME to which the eNodeB is connected. (default: Local Core Network, 127.0.1.100)",
      "default": [
        {
          "name": "Local Core Network",
          "mme_addr": "127.0.1.100"
        }
      ]
    },
    "plmn_list": {
      "$ref": "instance-enb-input-schema.json#/properties/plmn_list",
      "description": "List of PLMNs broadcasted by the eNodeB, at most 6 (default: 00101)",
      "default": [
        {
          "plmn": "00101"
        }
      ]
    },
    "gps_sync": {
      "$ref": "instance-enb-input-schema.json#/properties/gps_sync"
    },
    "gtp_addr": {
      "$ref": "instance-enb-input-schema.json#/properties/gtp_addr"
    },
    "ncell_list": {
      "title": "Neighbour Cell List",
      "description": "List of neighbour EUTRA or NR cells, handover will be configured for all neighbour cells. Tip: Copy Paste the handover-json-export connection parameter (on the Panel) from another ORS in the RAW XML to quickly fill in all parameters",
      "type": "array",
      "items": {
        "title": "Neighbour Cell",
        "type": "object",
        "unevaluatedProperties": false,
        "oneOf": [
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "LTE Peer Cell",
            "type": "object",
            "required": [
              "pci",
              "tac",
              "e_cell_id",
              "dl_earfcn",
              "plmn"
            ],
            "properties": {
              "name": {
                "$ref": "peer/cell/lte/input-schema.json#/properties/name"
              },
              "e_cell_id": {
                "$ref": "peer/cell/lte/input-schema.json#/properties/e_cell_id"
              },
              "dl_earfcn": {
                "$ref": "peer/cell/lte/input-schema.json#/properties/dl_earfcn"
              },
              "pci": {
                "$ref": "peer/cell/lte/input-schema.json#/properties/pci"
              },
              "tac": {
                "$ref": "peer/cell/lte/input-schema.json#/properties/tac"
              },
              "plmn": {
                "$ref": "peer/cell/lte/input-schema.json#/properties/plmn"
              }
            }
          },
          {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "NR Peer Cell",
            "type": "object",
            "required": [
              "pci",
              "tac",
              "nr_cell_id",
              "gnb_id_bits",
              "dl_nr_arfcn",
              "nr_band",
              "plmn"
            ],
            "properties": {
              "name": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/name"
              },
              "nr_cell_id": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/nr_cell_id"
              },
              "gnb_id_bits": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/gnb_id_bits"
              },
              "dl_nr_arfcn": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/dl_nr_arfcn"
              },
              "nr_band": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/nr_band"
              },
              "ssb_nr_arfcn": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/ssb_nr_arfcn"
              },
              "ul_nr_arfcn": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/ul_nr_arfcn"
              },
              "pci": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/pci"
              },
              "tac": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/tac"
              },
              "plmn": {
                "$ref": "peer/cell/nr/input-schema.json#/properties/plmn"
              }
            }
          }
        ]
      },
      "default": []
    },
    "x2_peers": {
      "title": "X2 Peers",
      "description": "List of IP addresses and optional port of other eNodeBs to establish X2 connections. The default port is 36422.",
      "type": "array",
      "items": {
        "title": "X2 Peer",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "title": "(Optional) Neighbour Cell Name",
            "description": "Neighbour Cell name (for management purposes only)",
            "type": "string"
          },
          "x2_addr": {
            "$ref": "peer/lte/input-schema.json#/properties/x2_addr"
          }
        }
      },
      "default": []
    },
    "xn_peers": {
      "title": "XN Peers",
      "description": "List of IP addresses and optional port of other eNodeBs to establish Xn connections. The default port is 38422.",
      "type": "array",
      "items": {
        "title": "XN Peer",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "title": "(Optional) Neighbour Cell Name",
            "description": "Neighbour Cell name (for management purposes only)",
            "type": "string"
          },
          "xn_addr": {
            "$ref": "peer/nr/input-schema.json#/properties/xn_addr"
          }
        }
      },
      "default": []
    },
    "eutra_eutra_handover": {
      "$ref": "instance-enb-input-schema.json#/properties/eutra_eutra_handover"
    },
    "eutra_nr_handover": {
      "$ref": "instance-enb-input-schema.json#/properties/eutra_nr_handover"
    },
    "nssai": {
      "$ref": "instance-enb-input-schema.json#/properties/nssai"
    },
    "nr_nr_handover": {
      "$ref": "instance-enb-input-schema.json#/properties/nr_nr_handover"
    },
    "nr_eutra_handover": {
      "$ref": "instance-enb-input-schema.json#/properties/nr_eutra_handover"
    },
    "gtp_payload_mtu": {
      "$ref": "instance-enb-input-schema.json#/properties/gtp_payload_mtu"
    },
    "mbmsgw_addr": {
      "$ref": "instance-enb-input-schema.json#/properties/mbmsgw_addr"
    },
    "inactivity_timer": {
      "$ref": "cell/common.json#/properties/inactivity_timer",
      "default": 10000
    },
    "handover_a1_rsrp": {
      "title": "Handover A1 event RSRP threshold",
      "description": "Integer, range from -140 to -43. RSRP threshold value in dBm.",
      "type": "number",
      "default": -70
    },
    "handover_a1_hysteresis": {
      "title": "Handover A1 event hysteresis",
      "description": "Integer, range from 0 to 30. A1 hysteresis in 0.5dB steps used for the measurement report triggering condition.",
      "type": "number",
      "default": 0
    },
    "handover_a1_time_to_trigger": {
      "title": "Handover A1 event time to trigger",
      "description": "Time in ms during which the A1 event condition must be met before triggering the measurement report.",
      "type": "number",
      "enum": [
        0,
        40,
        64,
        80,
        100,
        128,
        160,
        256,
        320,
        480,
        512,
        640,
        1024,
        1280,
        2560,
        5120
      ],
      "default": 640
    },
    "handover_a2_rsrp": {
      "title": "Handover A2 event RSRP threshold",
      "description": "Integer, range from -140 to -43. RSRP threshold value in dBm.",
      "type": "number",
      "default": -80
    },
    "handover_a2_hysteresis": {
      "title": "Handover A2 event hysteresis",
      "description": "Integer, range from 0 to 30. A2 hysteresis in 0.5dB steps used for the measurement report triggering condition.",
      "type": "number",
      "default": 0
    },
    "handover_a2_time_to_trigger": {
      "title": "Handover A2 event time to trigger",
      "description": "Time in ms during which the A2 event condition must be met before triggering the measurement report.",
      "type": "number",
      "enum": [
        0,
        40,
        64,
        80,
        100,
        128,
        160,
        256,
        320,
        480,
        512,
        640,
        1024,
        1280,
        2560,
        5120
      ],
      "default": 640
    },
    "handover_meas_gap_config": {
      "title": "Handover measurement gap configuration",
      "description": "Configuration of the measurement gap. Ignored if no neighbour cells are configured.",
      "type": "string",
      "enum": [
        "None",
        "Gap Pattern 0",
        "Gap Pattern 1"
      ],
      "default": "Gap Pattern 1"
    }
  }
}
