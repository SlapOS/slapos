{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ORS eNB / gNB Secondary",
  "type": "object",
  "properties": {
    "gps_sync": {
      "$ref": "instance-enb-input-schema.json#/properties/gps_sync"
    },
    "gtp_addr": {
      "$ref": "instance-enb-input-schema.json#/properties/gtp_addr"
    },
    "ncell_list": {
      "title": "Neighbour Cell Info",
      "description": "Neighbour Cell Info",
      "type": "array",
      "items": {
        "title": "Neighbour Cell",
        "type": "object",
        "unevaluatedProperties": false,
        "oneOf": [
          {
            "$ref": "peer/cell/lte/input-schema.json"
          },
          {
            "$ref": "peer/cell/nr/input-schema.json"
          }
        ]
      },
      "default": []
    },
    "x2_peers": {
      "title": "X2 Peers",
      "description": "X2 Peers",
      "type": "array",
      "items": {
        "title": "X2 Peer",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "title": "(Optional) Neighbour Cell Name",
            "description": "Neighbour Cell name (for management purposes only)",
            "type": "string"
          },
          "x2_addr": {
            "$ref": "peer/lte/input-schema.json#/properties/x2_addr"
          }
        }
      },
      "default": []
    },
    "xn_peers": {
      "title": "XN Peers",
      "description": "XN Peers",
      "type": "array",
      "items": {
        "title": "XN Peer",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {
            "title": "(Optional) Neighbour Cell Name",
            "description": "Neighbour Cell name (for management purposes only)",
            "type": "string"
          },
          "xn_addr": {
            "$ref": "peer/nr/input-schema.json#/properties/xn_addr"
          }
        }
      },
      "default": []
    }
  }
}
