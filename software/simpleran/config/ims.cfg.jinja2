{
    log_options: "all.level=debug,all.max_size=32",
    log_filename: "{{ directory['log'] }}/ims.log",

    com_addr: "{{ slapparameter_dict.ims_com_url }}",
{%- if not slapparameter_dict.com_unsecure %}
    com_auth: {
      password: "{{ websocket_password }}",
      unsecure: false,
    },
{%- endif %}

    sip_addr: [
        {addr: "{{ slapparameter_dict.ims_ipv4 }}", bind_addr: "{{ slapparameter_dict.ims_ipv4 }}", port_min: 10000, port_max: 20000
{%- if 'trunk' in slapparameter_dict -%}
        , trunk: true
{%- endif -%}
        },
        "{{ slapparameter_dict.ims_ipv6 }}",
    ],

{%- if 'trunk' in slapparameter_dict %}
    trunk: {
      addr: "{{ slapparameter_dict['trunk']['addr'] }}",
      name: "{{ slapparameter_dict['trunk']['name'] }}",
    }
{%- endif %}

    mms_server_bind_addr: "{{ slapparameter_dict.internet_ipv4 }}:1111",
    sctp_addr: "{{ slapparameter_dict.ims_addr }}",

    
    cx_server_addr: "127.0.1.100",
    cx_bind_addr: "{{ slapparameter_dict.ims_addr }}",

    rx_server_addr: "127.0.1.100",

    domain: "{{ slapparameter_dict.get('ims_domain', 'rapid.space') }}",

    include "{{ slap_configuration['ue_db_path'] }}",

    echo: [
        "tel:666",
        "tel:+666",
        {impu: "tel:404", code: 404},     
        {impu: "urn:service:sos", anonymous: true, authentication: false}, 
        {impu: "urn:service:sos.police", anonymous: true, authentication: false}, 
    ],
    
    precondition: "on",
    "100rel": true,
    
    ipsec_aalg_list: ["hmac-md5-96", "hmac-sha-1-96"],
    ipsec_ealg_list: ["null", "aes-cbc", "des-cbc", "des-ede3-cbc"],

    ipsec_ifname: "{{ slapparameter_dict.tun_name }}-ims",
    ipsec_netns: "{{ slapparameter_dict.tun_name }}-ims-netns",

    mt_call_sdp_file: "{{ directory['etc'] }}/mt_call_qos.sdp",

    ue_db_filename: "{{ directory['var'] }}/lte_ue_ims.db",
}
