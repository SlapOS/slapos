[slaposinstancenode]
instance-db-path = ${cdn-requester-configuration:instance-db-path}
requestinstance-db-path = ${cdn-requester-configuration:valided-instance-db-path}
domainvalidation-db-path = ${cdn-requester-configuration:domainvalidation-db-path}
shared = true
openssl-binary = ${cdn-requester-configuration:openssl}
dns-nameserver = ${slap-configuration:configuration.dns-nameserver}
dns-nameserver-port = ${slap-configuration:configuration.dns-nameserver-port}
key-file = ${slap-connection:key-file}
cert-file = ${slap-connection:cert-file}
computer-id = ${slap-connection:computer-id}
partition-id = ${slap-connection:partition-id}
server-url = ${slap-connection:server-url}
report-error = false
timestamp-path = ${buildout:directory}/.timestamp
instance-retention-delay = ${cdn-requester-configuration:instance-retention-delay}
