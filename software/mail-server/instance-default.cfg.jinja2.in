[buildout]
extends =
  ${monitor2-template:output}
  ${template-logrotate-base:output}
parts =
  cron-entry-logrotate
  directory
  lamp-frontend-promise
  snappymail
  password-php
  monitor-base
  publish-connection-information
  certificate-authority
  dovecot-promise
  postfix-promise
  apache-httpd-promise
  publish-shared
{% if slapparameter_dict['request-dns']['enable'] %}
  request-dns-entry
  request-dns-entry-autoconfig
  mail-config
{% endif %}
{% if slapparameter_dict['bogofilter']['enable'] %}
  bogofilter-directory
  bogofilter-scan-script
  bogofilter-learn-spam-script
  bogofilter-learn-ham-script
  bogofilter-sieve-spam-filter
  bogofilter-sieve-report-spam
  bogofilter-sieve-report-ham
{% endif %}
  request-relays


eggs-directory = ${buildout:eggs-directory}
develop-eggs-directory = ${buildout:develop-eggs-directory}
offline = true

[directory]
recipe = slapos.cookbook:mkdirectory
home = $${buildout:directory}
etc = $${:home}/etc
var = $${:home}/var
bin = $${:home}/bin
usr = $${:home}/usr
tmp = $${:home}/tmp
run = $${:var}/run
libexec = $${:usr}/libexec
script = $${:etc}/run
service = $${:etc}/service
log = $${:var}/log
var-log = $${:var}/log
var-lib = $${:var}/lib
var-spool = $${:var}/spool
vhosts = $${:home}/vhosts
srv = $${buildout:directory}/srv
apache.d = $${:etc}/apache.d
httpd-log = $${:log}/apache
php-ini-dir = $${:etc}/php
tmp-php = $${:tmp}/php
tmp-upload = $${:tmp}/upload
www = $${:srv}/www/

[ca-directory]
recipe = slapos.cookbook:mkdirectory
root = $${directory:srv}/ssl
requests = $${:root}/requests
private = $${:root}/private
certs = $${:root}/certs
newcerts = $${:root}/newcerts
crl = $${:root}/crl

[certificate-authority]
recipe = slapos.cookbook:certificate_authority
openssl-binary = ${openssl:location}/bin/openssl
ca-dir = $${ca-directory:root}
requests-directory = $${ca-directory:requests}
wrapper = $${directory:bin}/certificate_authority
ca-private = $${ca-directory:private}
ca-certs = $${ca-directory:certs}
ca-newcerts = $${ca-directory:newcerts}
ca-crl = $${ca-directory:crl}

[certificate-authority-service]
recipe = slapos.cookbook:wrapper
command-line = $${certificate-authority:wrapper}
wrapper-path = $${directory:services}/certificate_authority
hash-existing-files = $${buildout:directory}/software_release/buildout.cfg

[userinfo]
recipe = slapos.cookbook:userinfo

[ethernet-ip]
recipe = slapos.recipe.build
init =
  import netifaces
  for i in netifaces.interfaces():
      if not (i.startswith("slaptun") or i.startswith("re6stnet") or i == "lo"):
          a = netifaces.ifaddresses(i)
          if netifaces.AF_INET in a:
              try:
                  options['ipv4'] = a[netifaces.AF_INET][0]['addr']
              except:
                  options['ipv4'] = "0.0.0.0"

{% set mail_domains = slapparameter_dict['mail-domains'] -%}
{% set inbound_relay = slapparameter_dict['inbound-relay'] -%}
{% set outbound_relay = slapparameter_dict['outbound-relay'] -%}
{% set inbound = inbound_relay['enable'] -%}
{% set outbound = outbound_relay['enable'] -%}
{% set auto_outbound = outbound and inbound and not outbound_relay['host'] -%}
{% set custom_outbound = outbound and outbound_relay['host'] -%}
{% set custom_outbound_sasl = custom_outbound and outbound_relay['user'] -%}
[instance-parameters]
mail-domains = {{ dumps(mail_domains) }}
inbound-relay = {{ dumps(inbound_relay) }}
outbound-relay = {{ dumps(outbound_relay) }}
custom-outbound-relay = {{ dumps(custom_outbound) }}
custom-outbound-relay-sasl = {{ dumps(custom_outbound_sasl) }}
automatic-outbound-relay = {{ dumps(auto_outbound) }}


# Dovecot IMAP server
# -------------------

[dovecot-directory]
recipe = slapos.cookbook:mkdirectory
run = $${directory:run}/dovecot
var = $${directory:var}/dovecot
tmp = $${directory:tmp}/dovecot
libexec = $${directory:libexec}/dovecot
home = $${directory:home}/dovecot-home

[dovecot-conf]
recipe = slapos.recipe.template:jinja2
url = ${dovecot.jinja2.conf:target}
output = $${directory:etc}/dovecot.conf
imap-port = 10143
imaps-port = 10993
log-file = $${directory:var-log}/dovecot.log
bogofilter-enable = {{ dumps(slapparameter_dict['bogofilter']['enable']) }}
context =
  section directory directory
  section dovecot_directory dovecot-directory
  key dovecot_passwd dovecot-passwords:target
  raw user_name {{ user_name }}
  raw ipv6 {{ ipv6 }}
  raw imap_port $${:imap-port}
  raw imaps_port $${:imaps-port}
  raw postfix_auth $${postfix-directory:spool-private}/auth
  raw postfix_dovecot_lmtp $${postfix-directory:spool-private}/dovecot-lmtp
  raw dovecot_log_path $${:log-file}
  key ssl_cert postfix-certificate:cert-file
  key ssl_key postfix-certificate:key-file
  raw dovecot_plugin_dir ${dovecot-pigeonhole:location}/lib/dovecot
  key sendmail_path wrapper-sendmail:wrapper-path
  key bogofilter_enable :bogofilter-enable
{% if slapparameter_dict['bogofilter']['enable'] %}
  key sieve_before bogofilter-directory:sieve-before
  key sieve_pipe_bin_dir bogofilter-directory:sieve-pipe
  key sieve_report_spam bogofilter-sieve-report-spam:output
  key sieve_report_ham bogofilter-sieve-report-ham:output
{% endif %}

[dovecot-passwords]
recipe = slapos.recipe.build
# not using location to avoid Buildout ever deleting it
target = $${directory:etc}/dovecot-passwd
account-requests = {{ dumps(slave_instance_list) }}
init =
  # gecos and shell are unused by Dovecot so we can reuse them
  PASSWD_COLS = ['name', 'passwd', 'uid', 'gid', 'gecos', 'dir', 'shell', 'extra_fields']

  from itertools import chain, repeat
  import uuid

  try:
    with open(options['target'], 'r') as fp:
      passdb = fp.read()
  except:
    passdb = ""
  finally:
    previous = [dict(zip(PASSWD_COLS, chain(row.split(":"), repeat('')))) for row in filter(None, passdb.splitlines())]
    previous = {row['name']: row for row in previous}

  new_account_dict = {}
  error_dict = {}
  output = {}

  slave_list = options['account-requests']

  def make_entry(slave, previous={}):
    reset_token = slave['parameters'].get('reset-token')
    # if matching entry was already in passdb and is unchanged (no password reset, nothing to do), just forward it
    if previous and (reset_token is None or previous['gecos'] == reset_token):
      return previous
    addr = slave['parameters']['address']
    new_passwd = reset_token or str(uuid.uuid4())
    new_account_dict[slave['reference']] = {'address': addr, 'token': new_passwd}
    return {
      'name': addr,
      'passwd': new_passwd,
      'gecos': reset_token or '',
      'shell': slave['reference'],
      'extra_fields': 'fail',
    }

  # 1st pass: keep only slaves matching both address and reference ( = previously accepted slaves)
  for slave in slave_list:
    addr = slave['parameters']['address']

    if prev_entry := previous.get(addr):
      if prev_entry['shell'] == slave['reference']:
        output[addr] = make_entry(slave, previous=prev_entry)
      else:
        # address is already used by another slave, 2nd pass will handle it
        pass
    else:
      # no previous entry, will be handled in 2nd pass
      pass

  # 2nd pass: new entries + entries with different reference
  for slave in slave_list:
    addr = slave['parameters']['address']

    # If address was already processed in 1st pass
    if existing := output.get(addr):
      if existing['shell'] != slave['reference']:
        error_dict[slave['reference']] = {
          'address': addr,
          'error': 'address_already_used'
        }
      # (if it matches, there's nothing to do)
    else:
      # address wasn't in database, it's new
      output[addr] = make_entry(slave)

  options['new-account-dict'] = new_account_dict
  options['error-dict'] = error_dict

  if {{ slapparameter_dict['test-account'] }}:
    for domain in {{ repr(slapparameter_dict['mail-domains']) }}:
      test_mail = f"testmail@{domain}"
      if test_mail not in output:
        output[test_mail] = {
          'name': test_mail,
          'passwd': 'password123'
        }

  options['account-entries'] = output
  self.output = [":".join(row.get(col, '') for col in PASSWD_COLS) for row in output.values()]

  options['location'] = ''  # we don't care about the part folder existing
install =
  with open(options['target'], 'w') as fp:
    fp.write("\n".join(self.output))

[dovecot-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
inline =
  #!/bin/sh
  # If master.pid contains PID of any running process
  # dovecot will refuse to run. Only the pidfile provided
  # by wrapper recipe should be used
  rm -f var/run/dovecot/master.pid
  ${dovecot-pigeonhole:location}/sbin/dovecot -F -c $${dovecot-conf:output}

[dovecot-service]
recipe = slapos.cookbook:wrapper
command-line = $${dovecot-wrapper:output}
wrapper-path = $${directory:service}/dovecot
mode = 0775
pidfile = $${directory:run}/dovecot.pid
hash-files =
  $${dovecot-conf:output}
  $${dovecot-wrapper:output}
depends =
  $${logrotate-entry-dovecot:recipe}

[dovecot-promise]
<= monitor-promise-base
promise = check_socket_listening
name = imap_listen.py
config-host = {{ ipv6 }}
config-port = $${dovecot-conf:imap-port}
depends = $${dovecot-service:recipe}

[logrotate-entry-dovecot]
<= logrotate-entry-base
name = dovecot
log = $${dovecot-conf:log-file}
copytruncate = true


# Postfix SMTP server
# -------------------

{% set smtp_port = 10025 -%}

[postfix-directory]
recipe = slapos.cookbook:mkdirectory
usr = $${directory:usr}/postfix
etc = $${directory:etc}/postfix
ssl = $${:etc}/ssl
var-lib = $${directory:var-lib}/postfix
var-spool = $${directory:var-spool}/postfix
# Not used at buildout level, presence needed by postfix.
spool-active = $${:var-spool}/active
spool-bounce = $${:var-spool}/bounce
spool-corrupt = $${:var-spool}/corrupt
spool-defer = $${:var-spool}/defer
spool-deferred = $${:var-spool}/deferred
spool-flush = $${:var-spool}/flush
spool-hold = $${:var-spool}/hold
spool-incoming = $${:var-spool}/incoming
spool-maildrop = $${:var-spool}/maildrop
spool-pid = $${:var-spool}/pid
spool-private = $${:var-spool}/private
spool-public = $${:var-spool}/public
spool-saved = $${:var-spool}/saved
spool-trace = $${:var-spool}/trace

[postfix-certificate]
recipe = plone.recipe.command
stop-on-error = true
name = postfix-backend
key-file = $${postfix-directory:ssl}/$${:name}.key
cert-file = $${postfix-directory:ssl}/$${:name}.crt
fingerprint = $${postfix-directory:ssl}/$${:name}.digest
bundle = $${postfix-directory:ssl}/$${:name}.bundle.pem
openssl = ${openssl:location}/bin/openssl
command =
  test -e $${:key-file} || { \
    $${:openssl} req -newkey rsa -batch -new -sha256 -x509 -days 3650 -nodes \
      -keyout $${:key-file} -out $${:cert-file}; \
    $${:openssl} x509 -noout -fingerprint -sha256 -in $${:cert-file} \
      > $${:fingerprint}; \
    cat $${:key-file} $${:cert-file} > $${:bundle}; \
  }
update-command = $${:command}

[postfix-certificate-fingerprints]
recipe = slapos.recipe.build
fingerprint = $${postfix-certificate:fingerprint}
init =
  try:
    with open(options['fingerprint']) as f:
      # publish a list to allow for future fingerprint rotation
      options['tls-fingerprints'] = [f.read().split('=', 1)[1].strip()]
  except FileNotFoundError:
    # set invalid value to defer error and get as much work done now as possible
    options['tls-fingerprints'] = None

[postfix-conf-main]
recipe = slapos.recipe.template:jinja2
url = ${postfix_main.jinja2.cf:target}
output = $${postfix-directory:etc}/main.cf
log-file = $${directory:var-log}/postfix.log
bogofilter-enable = {{ dumps(slapparameter_dict['bogofilter']['enable']) }}
context =
  raw postfix_log_path $${:log-file}
  key sender_login_map postfix-sender-login-map:location
  key bin_directory directory:bin
  key usr_directory postfix-directory:usr
  key queue_directory postfix-directory:var-spool
  key data_directory postfix-directory:var-lib
  key spool_directory postfix-directory:var-spool
  key vhosts_directory directory:vhosts
  key log_directory directory:var-log
  key mail_owner userinfo:pw-name
  key setgid_group userinfo:gr-name
  raw server_fqdn {{ instance_title.replace(' ', '_') }}
  raw postfix_dovecot_lmtp $${postfix-directory:spool-private}/dovecot-lmtp
  key relay_map postfix-relays:output
  raw xz_utils_location ${xz-utils:location}
  raw postfix_location ${postfix:location}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  raw mail_domains {{ slapparameter_dict['mail-domains'] | join(',') }}
  section postfix_certificate postfix-certificate
  key relay_clientcerts postfix-relay-clientcerts:output
  section instance instance-parameters
{%- if custom_outbound_sasl %}
  key outbound_sasl_passwd postfix-custom-outbound-sasl:output
{%- endif %}
  key relay_tls_fingerprints request-relays:tls-fingerprints
  key bogofilter_enable :bogofilter-enable

[postfix-relay-clientcerts]
recipe = slapos.recipe.template:jinja2
output = $${postfix-directory:etc}/relay_clientcerts
context =
  section relays request-relays
{% raw -%}
inline =
  {% for fingerprint in relays['tls-fingerprints'] -%}
  {{ fingerprint.strip() }} mail-relay
  {% endfor %}
{%- endraw %}

[postfix-conf-master]
recipe = slapos.recipe.template:jinja2
url = ${postfix_master.jinja2.cf:target}
output = $${postfix-directory:etc}/master.cf
bogofilter-enable = {{ dumps(slapparameter_dict['bogofilter']['enable']) }}
context =
  raw smtp_port {{ smtp_port}}
  raw ipv4 {{ ipv4 }}
  raw ipv6 {{ ipv6 }}
  key bogofilter_enable :bogofilter-enable
  raw mail_owner {{ user_name }}
{% if slapparameter_dict['bogofilter']['enable'] %}
  key bogofilter_scan bogofilter-scan-script:output
  key bogofilter_spool bogofilter-directory:spool
{% endif %}

[postfix-sender-login-map]
recipe = slapos.recipe.template:jinja2
recipe = slapos.recipe.build
location = $${postfix-directory:etc}/sender_login_map
account-entries = $${dovecot-passwords:account-entries}
install =
  with open(location, 'w') as f:
    for address in options['account-entries']:
      f.write('%(address)s %(address)s\n' % {'address': address})

[outbound-relay-info]
<= instance-parameters
recipe = slapos.recipe.build
init =
  outbound_relay = options['outbound-relay']
  outbound_map = {}
  if options['custom-outbound-relay']:
    for domain in options['mail-domains']:
      outbound_map[domain] = outbound_relay
  elif options['automatic-outbound-relay']:
    prefix = 'connection-outbound-'
    for domain in options['mail-domains']:
      req_part = self.buildout['request-relay-' + domain]
      host, port = req_part[prefix + 'host'], req_part[prefix + 'smtp-port']
      outbound_map[domain] = {'host': host, 'port': port}
  options['outbound-map'] = outbound_map

[postfix-relays]
recipe = slapos.recipe.template:jinja2
url = ${postfix_relays.in:target}
output = $${postfix-directory:etc}/relay_by_sender
context =
  key outbound_map outbound-relay-info:outbound-map

{% if custom_outbound_sasl -%}
[postfix-custom-outbound-sasl]
recipe = slapos.recipe.template:jinja2
url = ${postfix_sasl_passwd.in:target}
output = $${postfix-directory:etc}/outbound_sasl_passwd
context =
  key out instance-parameters:outbound-relay
{%- endif %}

[postfix-symlinks-libexec]
recipe = slapos.cookbook:symbolic.link
target-directory = $${postfix-directory:usr}
link-binary =
    ${postfix:location}/usr/libexec

[postfix-wrapper]
recipe = slapos.recipe.template
output = $${directory:bin}/$${:_buildout_section_name_}
etc = $${postfix-directory:etc}
spool-pid = $${postfix-directory:spool-pid}
inline =
  #!/bin/sh
  # use postconf to produce a log in case of broken configuration
  ${postfix:location}/usr/sbin/postconf -c $${:etc} > /dev/null
  # remove old pidfiles
  rm -f $${:spool-pid}/*.pid
  # launch postfix
  ${postfix:location}/usr/libexec/postfix/master -c $${:etc}

[postfix-service]
recipe = slapos.cookbook:wrapper
command-line = $${postfix-wrapper:output}
wrapper-path = $${directory:service}/postfix
mode = 0775
pidfile = $${directory:run}/postfix.pid
environment =
  MAIL_CONFIG=$${postfix-directory:etc}
hash-files =
  $${postfix-conf-main:output}
  $${postfix-conf-master:output}
  $${postfix-wrapper:output}
{%- if custom_outbound_sasl %}
  $${postfix-custom-outbound-sasl:output}
{%- endif %}
depends =
  $${postfix-symlinks-libexec:recipe}
  $${logrotate-entry-postfix:recipe}

[postfix-service-master]
< = base-wrapper
command-line = $${directory:usr}/libexec/postfix/master -c $${postfix-directory:etc}
wrapper-path = $${directory:run}/postfix-master

[postfix-promise]
<= monitor-promise-base
promise = check_socket_listening
name = smtp_listen.py
config-host = {{ ipv6 }}
config-port = {{ smtp_port }}
depends =
  $${postfix-service:recipe}
  $${postfix-service-master:recipe}
  $${postfix-wrappers:depends}

[base-wrapper]
recipe = slapos.cookbook:wrapper
environment =
  MAIL_CONFIG=$${postfix-directory:etc}

[base-bin-wrapper]
< = base-wrapper
command-line = $${:path}/$${:basename}
wrapper-path = $${directory:bin}/$${:basename}

[base-bin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/bin

[base-sbin-bin-wrapper]
< = base-bin-wrapper
path = ${postfix:location}/usr/sbin

{% set postfix_wrappers = [] -%}
{% for extend, basename_list in (
  (
    'base-bin-bin-wrapper',
    (
      'mailq',
      'newaliases',
    ),
  ),
  (
    'base-sbin-bin-wrapper',
    (
      'postcat',
      'postconf',
      'postdrop',
      'postfix',
      'postkick',
      'postlock',
      'postlog',
      'postmap',
      'postmulti',
      'postqueue',
      'postsuper',
      'sendmail',
    ),
  ),
) %}
{%   for basename in basename_list -%}
{%     do postfix_wrappers.append('wrapper-' ~ basename) -%}
[wrapper-{{ basename }}]
< = {{ extend }}
basename = {{ basename }}
{%   endfor %}
{% endfor %}

[postfix-wrappers]
depends =
{%- for postfix_wrapper in postfix_wrappers %}
  {{ "$${" + postfix_wrapper + ":recipe" }}
{%- endfor %}

[logrotate-entry-postfix]
<= logrotate-entry-base
name = postfix
log = $${postfix-conf-main:log-file}
copytruncate = true

{% if slapparameter_dict['bogofilter']['enable'] %}
# Bogofilter spam filter (per-user, with sieve + imapsieve retraining)
# Based on: https://www.owlfish.com/thoughts/dovecot-bogofilter-antispam-2017-01-28.html
# ----------------------------------------------------------------------------
#
# Architecture:
#   1. Postfix pipes incoming (non-authenticated) mail through bogofilter
#      via smtpd_client_restrictions + FILTER action. Per-user bogofilter
#      databases (auto-created on first message).
#   2. Dovecot sieve filter (sieve_before) checks X-Bogosity header and
#      files spam into the Junk folder, marking it as read.
#   3. Dovecot imapsieve triggers retraining when users move messages
#      to/from Junk via IMAP.

[bogofilter-directory]
recipe = slapos.cookbook:mkdirectory
spool = $${directory:home}/bogofilter
sieve = $${directory:etc}/sieve
sieve-before = $${:sieve}/before
sieve-pipe = $${:sieve}/pipe

[bogofilter-scan-script]
recipe = slapos.recipe.template
output = $${directory:bin}/bogofilter-scan.sh
mode = 755
inline =
  #!/bin/sh
  # Per-user bogofilter scanning script for Postfix pipe transport.
  # Arg 1: per-user bogofilter DB directory
  # Arg 2: sender address
  # Arg 3: recipient address
  BOGODIR="$$1"
  SENDER="$$2"
  RECIPIENT="$$3"
  MAIL_CONFIG=$${postfix-directory:etc} ; export MAIL_CONFIG
  mkdir -p "$$BOGODIR"
  ${bogofilter:location}/bin/bogofilter -e -u -p -l -d "$$BOGODIR" \
    | ${postfix:location}/usr/sbin/sendmail -G -i -f "$$SENDER" "$$RECIPIENT"
  exit $$?

[bogofilter-learn-spam-script]
recipe = slapos.recipe.template
output = $${bogofilter-directory:sieve-pipe}/bogofilter-learn-spam.sh
mode = 755
inline =
  #!/bin/sh
  # Called by imapsieve when a message is moved TO the Junk folder.
  USER="$$1"
  BOGODIR="$${bogofilter-directory:spool}/$$USER"
  [ -d "$$BOGODIR" ] || exit 0
  ${bogofilter:location}/bin/bogofilter -e -Ns -d "$$BOGODIR"

[bogofilter-learn-ham-script]
recipe = slapos.recipe.template
output = $${bogofilter-directory:sieve-pipe}/bogofilter-learn-ham.sh
mode = 755
inline =
  #!/bin/sh
  # Called by imapsieve when a message is moved FROM the Junk folder.
  USER="$$1"
  BOGODIR="$${bogofilter-directory:spool}/$$USER"
  [ -d "$$BOGODIR" ] || exit 0
  ${bogofilter:location}/bin/bogofilter -e -Sn -d "$$BOGODIR"

[bogofilter-sieve-spam-filter]
recipe = slapos.recipe.template
output = $${bogofilter-directory:sieve-before}/spam-folder.sieve
mode = 644
inline =
  require ["regex", "fileinto", "imap4flags"];
  if header :regex "X-Bogosity" "^(Spam)" {
    setflag "\\Seen";
    fileinto "Junk";
    stop;
  }

[bogofilter-sieve-report-spam]
recipe = slapos.recipe.template
output = $${bogofilter-directory:sieve}/report-spam.sieve
mode = 644
inline =
  require ["vnd.dovecot.pipe", "copy", "imapsieve", "environment", "variables"];
  if environment :matches "imap.user" "*" {
    set "user" "{{ '$' }}{{ '$' }}{1}";
  }
  pipe :copy "bogofilter-learn-spam.sh" ["{{ '$' }}{{ '$' }}{user}"];

[bogofilter-sieve-report-ham]
recipe = slapos.recipe.template
output = $${bogofilter-directory:sieve}/report-ham.sieve
mode = 644
inline =
  require ["vnd.dovecot.pipe", "copy", "imapsieve", "environment", "variables"];
  if environment :matches "imap.user" "*" {
    set "user" "{{ '$' }}{{ '$' }}{1}";
  }
  pipe :copy "bogofilter-learn-ham.sh" ["{{ '$' }}{{ '$' }}{user}"];

{% endif %}

# SnappyMail Webmail
# -------------------

[snappymail-files]
recipe = plone.recipe.command
target = $${directory:www}
plugins = $${:target}/data/_data_/_default_/plugins/
command = cp -ax ${snappymail:location}/. $${:target} && mkdir -p $${:plugins} && cp -ax ${snappymail-plugins:location}/* $${:plugins}
stop-on-error = true

[snappymail-admin-pw]
recipe = slapos.cookbook:generate.password
username = admin

[snappymail-conf]
recipe = slapos.recipe.template:jinja2
depends = $${snappymail-files:recipe}
url = ${template-snappymail.jinja2.ini:target}
output = $${snappymail-files:target}/data/_data_/_default_/configs/application.ini
context =
  raw mail_domain {{ slapparameter_dict['mail-domains'][0] }}
  key admin_password snappymail-admin-pw:passwd-sha256-crypt

[snappymail-pw-conf]
recipe = slapos.recipe.template
output = $${snappymail-files:target}/data/_data_/_default_/configs/plugin-change-password.json
mode = 600
inline =
  {
      "plugin": {
          "pass_min_length": 10,
          "pass_min_strength": 20,
          "check_hibp": false,
          "driver_dovecot_enabled": true,
          "driver_dovecot_passwd_file": "$${dovecot-passwords:target}"
      }
  }

[snappymail-import-dovecot-conf]
recipe = slapos.recipe.template
output = $${snappymail-files:target}/data/_data_/_default_/configs/plugin-import-dovecot.json
mode = 600
inline =
  {
      "plugin": {
          "doveadm_path": "${dovecot-pigeonhole:location}/bin/doveadm",
          "dovecot_config": "$${dovecot-conf:output}",
          "temp_dir": "$${directory:tmp-upload}",
          "max_file_size_mb": 250
      }
  }

[snappymail-mailbox-conf]
recipe = slapos.recipe.template
output = $${snappymail-files:target}/data/_data_/_default_/configs/plugin-mailbox-detect.json
mode = 600
inline =
  {
      "plugin": {
          "autocreate_system_folders": true
      }
  }

[snappymail-domain]
recipe = slapos.recipe.template:jinja2
depends = $${snappymail-files:recipe}
url = ${template-snappymail-domain.jinja2.json:target}
output = $${snappymail-files:target}/data/_data_/_default_/domains/default.json
context =
  raw mail_host [{{ ipv6 }}]
  raw smtp_port {{ smtp_port }}
  key imap_port dovecot-conf:imap-port

[snappymail]
recipe = slapos.recipe.build
init =
  ""
depends =
  $${snappymail-conf:recipe}
  $${snappymail-domain:recipe}
  $${snappymail-pw-conf:recipe}
  $${snappymail-import-dovecot-conf:recipe}
  $${snappymail-mailbox-conf:recipe}


# Password reset page
# -------------------

[password-php]
recipe = slapos.recipe.template:jinja2
url = ${password.php.in:target}
output = $${directory:www}/password.php
context =
  key dovecot_passwd dovecot-passwords:target

{% if slapparameter_dict['request-dns']['enable'] %}
# Mail Autoconfig
# ---------------

[mail-config-directory]
recipe = slapos.cookbook:mkdirectory
root = $${directory:www}/autoconfig
mail = $${:root}/mail

[mail-config]
recipe = slapos.recipe.template:jinja2
url = ${mail-config.jinja2.xml:target}
output = $${mail-config-directory:mail}/config-v1.1.xml
context =
  key domain request-dns-entry:connection-domain
  key imap_port dovecot-conf:imap-port
  raw smtp_port {{ smtp_port }}
{% endif %}


# Apache/PHP server
# -----------------

[apache-network-configuration]
listening-ip = {{ ipv6 }}
http-port = 8080
https-port = 8081

[apache-php-service]
recipe = slapos.cookbook:wrapper
command-line = $${ca-apache-php:wrapper}
wrapper-path = $${directory:service}/apache-php
hash-existing-files = $${buildout:directory}/software_release/buildout.cfg
depends =
  $${logrotate-entry-apache:recipe}
  $${snappymail-files:recipe}
  $${apache-graceful:recipe}
  $${lamp-apache-httpd-conf:recipe}
  $${php.ini-conf:recipe}

[apache-graceful]
recipe = slapos.recipe.template
output = $${directory:script}/apache-httpd-graceful
mode = 700
inline =
  #!/bin/sh
  {{ bin_directory }}/slapos-kill -s USR1 --pidfile '$${apache-php-configuration:pid-file}'

[apache-php-conf]
recipe = slapos.recipe.template:jinja2
url = ${template-apache.conf:target}
output = $${directory:etc}/apache.conf
context =
  section parameter_dict apache-php-configuration
extensions = jinja2.ext.do

[apache-php-wrapper]
recipe = slapos.cookbook:wrapper
wrapper-path = $${directory:bin}/apache-wrapper
command-line = "${apache:location}/bin/httpd" -f "$${apache-php-conf:output}" -DFOREGROUND
wait-for-files =
  $${ca-directory:certs}/httpd.crt
  $${ca-directory:certs}/httpd.key

[apache-php-configuration]
document-root = $${directory:www}
autoconfig-root = $${directory:www}/autoconfig
pid-file = $${directory:run}/apache.pid
lock-file = $${directory:run}/apache.lock
ip = $${apache-network-configuration:listening-ip}
http-port = $${apache-network-configuration:http-port}
https-port = $${apache-network-configuration:https-port}
url = https://[$${:ip}]:$${:https-port}/
error-log = $${directory:httpd-log}/error.log
access-log = $${directory:httpd-log}/access.log
log-dir = $${directory:httpd-log}
php-ini-dir = $${directory:php-ini-dir}
cert-file = $${ca-directory:certs}/httpd.crt
key-file = $${ca-directory:certs}/httpd.key
apache-config-dir = $${directory:apache.d}

[instance-parameter]
document-root = $${apache-php-configuration:document-root}
backend-url = $${apache-php-configuration:url}
php-bin = ${apache-php:location}/bin/php
php-ini = $${php.ini-conf:output}

[php.ini-configuration]
tmp-dir = $${directory:tmp-php}
php-upload-dir = $${directory:tmp-upload}

[php.ini-conf]
recipe = slapos.recipe.template:jinja2
url = ${template-php.ini:target}
output = $${directory:php-ini-dir}/php.ini
context =
  section apache_parameter_dict php.ini-configuration
  section instance_dict instance-parameter
extensions = jinja2.ext.do

[php-bin]
recipe = slapos.cookbook:wrapper
wrapper-path = $${directory:bin}/php
command-line = $${instance-parameter:php-bin} -c $${php.ini-conf:output}

[lamp-apache-httpd-conf]
recipe = slapos.recipe.template:jinja2
url = ${template-apache-httpd:target}
output = $${directory:apache.d}/lamp.conf
context =
  section parameter_dict apache-php-configuration

[lamp-frontend-promise]
<= monitor-promise-base
promise = check_url_available
name = lamp-http-frontend.py
url = $${request-frontend:connection-secure_access}
config-url = $${:url}

# TODO: use openssl like in relay at a later stage
[ca-apache-php]
<= certificate-authority
recipe = slapos.cookbook:certificate_authority.request
key-file = $${apache-php-configuration:key-file}
cert-file = $${apache-php-configuration:cert-file}
executable = $${apache-php-wrapper:wrapper-path}
wrapper = $${directory:bin}/ca-apache-php

[apache-httpd-promise]
# Check any apache port in ipv4, expect other ports and ipv6 to behave consistently
<= monitor-promise-base
promise = check_socket_listening
name = apache-httpd-port-listening.py
config-host = $${apache-php-configuration:ip}
config-port = $${apache-php-configuration:https-port}
depends = $${apache-php-service:recipe}

[request-frontend]
<= monitor-frontend
name = Instance Frontend
config-url = $${apache-php-configuration:url}

[logrotate-entry-apache]
<= logrotate-entry-base
name = apache
log = $${directory:httpd-log}/*.log
sharedscripts = true
post = $${directory:script}/apache-httpd-graceful


# Shared instances (addresses)
# ----------------------------

[publish-shared]
recipe = slapos.recipe.build
new-account-dict = $${dovecot-passwords:new-account-dict}
error-dict = $${dovecot-passwords:error-dict}
pw-url = $${publish-connection-information:webmail-url}/password.php
init =
  for ref, content in options['new-account-dict'].items():
    self.buildout.parse(f"""
  [publish-{ref}]
  recipe = slapos.cookbook:publish.serialised
  -slave-reference = {ref}
  address = {content['address']}
  token = {content['token']}
  setup-url = {options['pw-url']}?user={content['address']}&token={content['token']}
    """)

  for ref, content in options['error-dict'].items():
    self.buildout.parse(f"""
  [publish-{ref}]
  recipe = slapos.cookbook:publish.serialised
  -slave-reference = {ref}
  address = {content['address']}
  error = {content['error']}
    """)


# Request relay
# -------------

{% set relay_requests = [] -%}
{% for mail_domain in slapparameter_dict['mail-domains'] -%}
{%   do relay_requests.append('request-relay-' ~ mail_domain) %}
[request-relay-{{ mail_domain }}]
<= slap-connection
software-url = {{ inbound_relay['relay-sr-url'] }}
software-type = cluster
shared = true
name = mail-server-relay-{{ mail_domain }}
config-name = {{ mail_domain }}
config-mail-server-host = {{ ipv6 }}
config-mail-server-port = {{ dumps(smtp_port) }}
config-authentication = fingerprint
config-fingerprints = $${postfix-certificate-fingerprints:tls-fingerprints}
{% if inbound_relay['enable'] %}
recipe = slapos.cookbook:request.serialised
return =
  outbound-host
  outbound-smtp-port
  tls-fingerprints
{% else -%}
recipe = slapos.cookbook:requestoptional.serialised
state = destroyed
{% endif %}
{% endfor %}

[request-relays]
recipe = slapos.recipe.build
relay-requests = {{ dumps(relay_requests) }}
{% if not inbound_relay['enable'] -%}
init =
  options['tls-fingerprints'] = []
depends =
{%- for relay_request in relay_requests %}
  {{ "$${" + relay_request + ":recipe}" }}
{%- endfor %}
{% else -%}
init =
  fingerprints = {} # deterministic insertion-ordered dict in Python3
  for section in options['relay-requests']:
    part = self.buildout[section]
    fingerprints.update((f, 0) for f in part['connection-tls-fingerprints'])
  options['tls-fingerprints'] = list(fingerprints)
{%- endif %}


# Request local DNS entry
# -----------------------

[macro.request-dns-entry]
<= slap-connection
name = dns-mail-entry
recipe = slapos.cookbook:request.serialised
software-url = {{ slapparameter_dict['request-dns']['sr-url'] }}
software-type = {{ slapparameter_dict['request-dns']['sr-type'] }}
shared = true
sla-computer_guid = $${slap-connection:computer-id}
return = domain ip

[request-dns-entry]
<= macro.request-dns-entry
config-name = dns-mail-entry
config-subdomain = mail
config-ip = {{ ipv6 }}

[request-dns-entry-autoconfig]
<= macro.request-dns-entry
config-name = dns-mail-entry-autoconfig
config-subdomain = autoconfig.mail
config-ip = {{ ipv6 }}


# Publish connection information
# ------------------------------

[publish-connection-information]
recipe = slapos.cookbook:publish.serialised
<= monitor-publish
imap-port = $${dovecot-conf:imap-port}
imaps-port = $${dovecot-conf:imaps-port}
smtp-port = {{ smtp_port }}
imap-smtp-ipv6 = {{ ipv6 }}
webmail-url = $${lamp-frontend-promise:url}
webmail-admin-password = $${snappymail-admin-pw:passwd}
password-url = $${:webmail-url}/password.php
slaves = $${dovecot-passwords:new-account-dict}
error-dict = $${dovecot-passwords:error-dict}
{% if slapparameter_dict['request-dns']['enable'] %}
domain = $${request-dns-entry:connection-domain}
{% endif %}

