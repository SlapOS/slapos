+        source = self._makeSourceFile('AAABBBB')
+        options = self._makeOptions(quick=True, file=source)
+        self._makeFile(2, 3, 4, '.fs', 'AAA')
+        self._makeFile(4, 5, 6, '.deltafs', 'BBBB')
+        self._makeFile(
